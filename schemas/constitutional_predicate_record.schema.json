{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/constitutional_predicate_record.schema.json",
  "title": "Constitutional Predicate Record",
  "type": "object",
  "required": [
    "predicate_id",
    "normative_source",
    "commitment",
    "operational_test",
    "protected_scope",
    "translation_status",
    "conflict_behavior",
    "uncertainty",
    "review_route",
    "self_modification_rule",
    "migration_policy",
    "non_claims"
  ],
  "properties": {
    "predicate_id": { "type": "string", "minLength": 1 },
    "normative_source": { "type": "string", "minLength": 1 },
    "commitment": { "type": "string", "minLength": 1 },
    "operational_test": { "type": "string", "minLength": 1 },
    "protected_scope": { "type": "array", "items": { "type": "string" } },
    "translation_status": {
      "type": "string",
      "enum": ["operational", "partial", "speculative_lineage"]
    },
    "conflict_behavior": { "type": "string", "minLength": 1 },
    "uncertainty": { "type": "array", "items": { "type": "string" } },
    "review_route": { "type": "string", "minLength": 1 },
    "self_modification_rule": { "type": "string", "minLength": 1 },
    "migration_policy": { "type": "string", "minLength": 1 },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
