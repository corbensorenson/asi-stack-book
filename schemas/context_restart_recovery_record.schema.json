{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://corbensorenson.github.io/asi-stack-book/schemas/context_restart_recovery_record.schema.json","title":"Context Restart Recovery Record","type":"object",
  "required":["record_id","source_ids","initial_state","transitions","restart_observation","decision","promotion_blockers","non_claims"],
  "properties":{
    "record_id":{"type":"string","minLength":1},
    "source_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},
    "initial_state":{"$ref":"#/$defs/state"},
    "transitions":{"type":"array","minItems":7,"items":{"type":"object","required":["operation","pre_state","post_state","postcondition","effect_observed","acknowledged","no_loss_required","partial_write_detected","ordinary_commit_allowed","recovery_action"],"properties":{"operation":{"enum":["freeze","thaw","rebalance","promote","compact","partial_write_recovery","restart"]},"pre_state":{"$ref":"#/$defs/state"},"post_state":{"$ref":"#/$defs/state"},"postcondition":{"type":"string","minLength":1},"effect_observed":{"type":"boolean"},"acknowledged":{"type":"boolean"},"no_loss_required":{"type":"boolean"},"partial_write_detected":{"type":"boolean"},"ordinary_commit_allowed":{"type":"boolean"},"recovery_action":{"type":"string","minLength":1}},"additionalProperties":false}},
    "restart_observation":{"type":"object","required":["visible_item_ids","index_epoch","content_epoch","recovered_generation","evidence_refs"],"properties":{"visible_item_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string"}},"index_epoch":{"type":"integer","minimum":0},"content_epoch":{"type":"integer","minimum":0},"recovered_generation":{"type":"integer","minimum":1},"evidence_refs":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}},"additionalProperties":false},
    "decision":{"type":"object","required":["state","ordinary_use_allowed","support_state_effect"],"properties":{"state":{"enum":["recovered_for_bounded_use","blocked","quarantined"]},"ordinary_use_allowed":{"type":"boolean"},"support_state_effect":{"enum":["none","blocks_promotion","eligible_for_bounded_evidence_review"]}},"additionalProperties":false},
    "promotion_blockers":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"non_claims":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}
  },"additionalProperties":false,
  "$defs":{"state":{"type":"object","required":["state_ref","generation","lifecycle","tier","item_ids","index_epoch","content_epoch"],"properties":{"state_ref":{"type":"string","minLength":1},"generation":{"type":"integer","minimum":1},"lifecycle":{"enum":["active","frozen","recovering"]},"tier":{"enum":["hot","warm","cold"]},"item_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"index_epoch":{"type":"integer","minimum":0},"content_epoch":{"type":"integer","minimum":0}},"additionalProperties":false}}
}
