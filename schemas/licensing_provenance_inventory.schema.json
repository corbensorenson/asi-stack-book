{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/licensing_provenance_inventory.schema.json",
  "title": "ASI Stack Licensing Provenance Inventory",
  "type": "object",
  "required": ["schema_version", "decision_state", "operative_license", "generated_from", "summary", "files", "non_claims"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["asi_stack.licensing_provenance_inventory.v0"] },
    "decision_state": { "type": "string", "const": "awaiting_author_decision" },
    "operative_license": { "type": "string", "const": "all_rights_reserved_no_permission_granted" },
    "generated_from": {
      "type": "object",
      "required": ["policy", "policy_sha256", "file_set_command", "path_set_sha256"],
      "properties": {
        "policy": { "type": "string", "const": "licensing/provenance_policy.json" },
        "policy_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "file_set_command": { "type": "string", "minLength": 1 },
        "path_set_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["file_count", "by_artifact_class", "by_provenance_status", "by_candidate_lane", "unknown_quarantine_count"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 1 },
        "by_artifact_class": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "by_provenance_status": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "by_candidate_lane": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "unknown_quarantine_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "rule_id", "artifact_class", "provenance_status", "candidate_lane", "current_effect", "blocking_reason"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "rule_id": { "type": "string", "minLength": 1 },
          "artifact_class": { "type": "string", "minLength": 1 },
          "provenance_status": { "type": "string", "minLength": 1 },
          "candidate_lane": { "type": "string", "minLength": 1 },
          "current_effect": { "type": "string", "const": "all_rights_reserved_no_permission_granted" },
          "blocking_reason": { "type": "string", "minLength": 24 }
        },
        "additionalProperties": false
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
