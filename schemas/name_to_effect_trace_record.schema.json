{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/name_to_effect_trace_record.schema.json",
  "title": "Name-to-Effect Trace Record",
  "type": "object",
  "required": ["trace_id", "source_ids", "request", "policy_decision", "state_selection", "name_to_effect_map", "effect", "receipt", "evaluator", "claim_boundary", "promotion_blockers", "non_claims"],
  "properties": {
    "trace_id": {"type": "string", "minLength": 1},
    "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "request": {
      "type": "object",
      "required": ["request_id", "derived_input_ref", "request_digest", "authority_ref"],
      "properties": {
        "request_id": {"type": "string", "minLength": 1},
        "derived_input_ref": {"type": "string", "minLength": 1},
        "request_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "authority_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "policy_decision": {
      "type": "object",
      "required": ["policy_ref", "decision_id", "decision", "request_id"],
      "properties": {
        "policy_ref": {"type": "string", "minLength": 1},
        "decision_id": {"type": "string", "minLength": 1},
        "decision": {"enum": ["allow", "deny", "escalate"]},
        "request_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "state_selection": {
      "type": "object",
      "required": ["canonical_state_ref", "canonical_state_digest", "projection_refs", "selection_receipt_ref"],
      "properties": {
        "canonical_state_ref": {"type": "string", "minLength": 1},
        "canonical_state_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "projection_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "selection_receipt_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "name_to_effect_map": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "required": ["stage", "owner", "input_refs", "output_ref", "authority"],
        "properties": {
          "stage": {"enum": ["request_derived_input", "policy", "canonical_state_selection", "effect", "receipt", "evaluator", "claim_boundary"]},
          "owner": {"type": "string", "minLength": 1},
          "input_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "output_ref": {"type": "string", "minLength": 1},
          "authority": {"enum": ["canonical", "projection", "observed_effect", "evaluation", "claim_gate"]}
        },
        "additionalProperties": false
      }
    },
    "effect": {
      "type": "object",
      "required": ["effect_id", "target_ref", "effect_type", "observed_digest", "terminal_state"],
      "properties": {
        "effect_id": {"type": "string", "minLength": 1},
        "target_ref": {"type": "string", "minLength": 1},
        "effect_type": {"enum": ["write", "execute", "publish", "quarantine", "no_effect"]},
        "observed_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "terminal_state": {"enum": ["completed", "failed", "denied", "unknown"]}
      },
      "additionalProperties": false
    },
    "receipt": {
      "type": "object",
      "required": ["receipt_id", "request_id", "request_digest", "decision_id", "canonical_state_digest", "effect_id", "effect_digest", "acknowledged_terminal_state"],
      "properties": {
        "receipt_id": {"type": "string", "minLength": 1},
        "request_id": {"type": "string", "minLength": 1},
        "request_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "decision_id": {"type": "string", "minLength": 1},
        "canonical_state_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "effect_id": {"type": "string", "minLength": 1},
        "effect_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "acknowledged_terminal_state": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "evaluator": {
      "type": "object",
      "required": ["evaluation_id", "effect_id", "receipt_id", "method", "producer_id", "verifier_id", "independence", "result"],
      "properties": {
        "evaluation_id": {"type": "string", "minLength": 1},
        "effect_id": {"type": "string", "minLength": 1},
        "receipt_id": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1},
        "producer_id": {"type": "string", "minLength": 1},
        "verifier_id": {"type": "string", "minLength": 1},
        "independence": {"enum": ["same_component", "separate_route", "independent_external", "unknown"]},
        "result": {"enum": ["pass", "fail", "abstain", "not_attempted"]}
      },
      "additionalProperties": false
    },
    "claim_boundary": {
      "type": "object",
      "required": ["claim_ref", "current_support_state", "support_state_effect", "allowed_statement"],
      "properties": {
        "claim_ref": {"type": "string", "minLength": 1},
        "current_support_state": {"enum": ["argument", "prototype-backed", "empirical-test-backed", "externally-reproduced"]},
        "support_state_effect": {"enum": ["none", "blocks_promotion", "eligible_for_bounded_evidence_review"]},
        "allowed_statement": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "promotion_blockers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false
}
