{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/narrative_product_spine.schema.json",
  "title": "ASI Stack Narrative Product Spine",
  "type": "object",
  "required": [
    "schema_version",
    "product_id",
    "status",
    "selection_rule",
    "chapters",
    "omission_policy",
    "review_gate",
    "non_claims"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["asi_stack.narrative_product_spine.v0"]
    },
    "product_id": {
      "type": "string",
      "const": "narrative_book"
    },
    "status": {
      "type": "string",
      "const": "generated_candidate_spine_not_a_reviewed_reader_release"
    },
    "selection_rule": {
      "type": "string",
      "minLength": 1
    },
    "chapters": {
      "type": "array",
      "minItems": 12,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": [
          "order",
          "chapter_id",
          "core_claim_ref",
          "reader_question",
          "running_example",
          "strongest_objection",
          "failure_story",
          "evidence_that_would_change_the_conclusion",
          "handoff"
        ],
        "properties": {
          "order": { "type": "integer", "minimum": 1, "maximum": 15 },
          "chapter_id": { "type": "string", "minLength": 1 },
          "core_claim_ref": { "type": "string", "pattern": "^[a-z0-9-]+\\.core$" },
          "reader_question": { "type": "string", "minLength": 24 },
          "running_example": { "type": "string", "minLength": 24 },
          "strongest_objection": { "type": "string", "minLength": 24 },
          "failure_story": { "type": "string", "minLength": 24 },
          "evidence_that_would_change_the_conclusion": { "type": "string", "minLength": 24 },
          "handoff": { "type": "string", "minLength": 24 }
        },
        "additionalProperties": false
      }
    },
    "omission_policy": {
      "type": "string",
      "minLength": 1
    },
    "review_gate": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "non_claims": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
