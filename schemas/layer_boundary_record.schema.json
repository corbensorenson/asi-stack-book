{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/layer_boundary_record.schema.json",
  "title": "Layer Boundary Record",
  "type": "object",
  "required": [
    "layer_id",
    "lifecycle_state",
    "owner",
    "responsibility",
    "input_artifacts",
    "output_artifacts",
    "authority_ceiling",
    "handoff_protocol",
    "contract_refs",
    "change_policy",
    "owned_invariants",
    "failure_modes",
    "evidence_gates",
    "downstream_interfaces",
    "source_refs",
    "support_state_effect",
    "non_claims"
  ],
  "properties": {
    "layer_id": { "type": "string", "minLength": 1 },
    "lifecycle_state": {
      "type": "string",
      "enum": ["proposed", "conceptual", "schema_backed", "fixture_validated", "implemented", "deprecated", "retired"]
    },
    "owner": { "type": "string", "minLength": 1 },
    "responsibility": { "type": "string", "minLength": 1 },
    "input_artifacts": { "type": "array", "items": { "type": "string" } },
    "output_artifacts": { "type": "array", "items": { "type": "string" } },
    "authority_ceiling": { "type": "string", "minLength": 1 },
    "handoff_protocol": { "type": "string", "minLength": 1 },
    "contract_refs": { "type": "array", "items": { "type": "string" } },
    "change_policy": { "type": "string", "minLength": 1 },
    "owned_invariants": { "type": "array", "items": { "type": "string" } },
    "failure_modes": { "type": "array", "items": { "type": "string" } },
    "evidence_gates": { "type": "array", "items": { "type": "string" } },
    "downstream_interfaces": { "type": "array", "items": { "type": "string" } },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "support_state_effect": {
      "type": "string",
      "enum": [
        "none",
        "record_shape_only",
        "argument_only",
        "eligible_for_bounded_evidence_review",
        "blocks_promotion"
      ]
    },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
