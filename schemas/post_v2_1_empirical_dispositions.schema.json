{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/post_v2_1_empirical_dispositions.schema.json",
  "title": "Post-v2.1 Empirical Core Dispositions",
  "type": "object",
  "required": ["schema_version", "decision_set_id", "recorded_date", "review_status", "program_count", "component_disposition_count", "affected_core_claim_count", "transition_refs", "decisions", "summary", "non_claims"],
  "properties": {
    "schema_version": {"const": "asi_stack.post_v2_1_empirical_dispositions.v0"},
    "decision_set_id": {"const": "post-v2-1-empirical-dispositions-2026-07-11"},
    "recorded_date": {"const": "2026-07-11"},
    "review_status": {"const": "accepted_internal_no_external_human_review"},
    "program_count": {"const": 3},
    "component_disposition_count": {"const": 6},
    "affected_core_claim_count": {"const": 14},
    "transition_refs": {"type": "array", "minItems": 6, "maxItems": 6, "uniqueItems": true, "items": {"type": "string"}},
    "decisions": {"type": "array", "minItems": 14, "maxItems": 14, "items": {"$ref": "#/$defs/decision"}},
    "summary": {"type": "object", "required": ["no_change", "promote", "narrow_core", "demote", "refute", "support_state_changes"], "properties": {"no_change": {"const": 14}, "promote": {"const": 0}, "narrow_core": {"const": 0}, "demote": {"const": 0}, "refute": {"const": 0}, "support_state_changes": {"const": 0}}, "additionalProperties": false},
    "non_claims": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "decision": {
      "type": "object",
      "required": ["claim_id", "chapter_id", "program_components", "empirical_dispositions", "core_decision", "current_support_state", "support_state_effect", "result_ref", "transition_refs", "basis", "remaining_burden"],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^[a-z0-9-]+\\.core$"},
        "chapter_id": {"type": "string", "minLength": 1},
        "program_components": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "empirical_dispositions": {"type": "array", "minItems": 1, "items": {"enum": ["narrow", "no_change"]}},
        "core_decision": {"const": "no_change"},
        "current_support_state": {"const": "argument"},
        "support_state_effect": {"const": "none"},
        "result_ref": {"const": "experiments/post_v2_1_evidence_program/results/2026-07-11-post-v2-1-outcomes.json"},
        "transition_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "basis": {"type": "string", "minLength": 100},
        "remaining_burden": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
