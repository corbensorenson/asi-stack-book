{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://corbensorenson.github.io/asi-stack-book/schemas/contradiction_revision_lifecycle_record.schema.json","title":"Contradiction Revision Lifecycle Record","type":"object",
  "required":["record_id","source_ids","claim_identity","separated_states","contradiction_sequence","revision","dependency_repair","ontology_migration","restart_persistence","decision","promotion_blockers","non_claims"],
  "properties":{
    "record_id":{"type":"string","minLength":1},"source_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},
    "claim_identity":{"type":"object","required":["claim_id","claim_text_digest","ontology_id","ontology_version"],"properties":{"claim_id":{"type":"string","minLength":1},"claim_text_digest":{"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},"ontology_id":{"type":"string","minLength":1},"ontology_version":{"type":"string","minLength":1}},"additionalProperties":false},
    "separated_states":{"type":"object","required":["justification_state","justification_refs","lifecycle_state","commitment_state","authority_state"],"properties":{"justification_state":{"enum":["supported","contested","insufficient","refuted"]},"justification_refs":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"lifecycle_state":{"enum":["recorded","challenged","revised","superseded","retired"]},"commitment_state":{"enum":["withheld","provisional","committed","withdrawn"]},"authority_state":{"enum":["no_action_authority","advisory_only","bounded_action_authority"]}},"additionalProperties":false},
    "contradiction_sequence":{"type":"array","minItems":3,"maxItems":3,"items":{"type":"object","required":["event_id","strength","strength_rank","evidence_ref","response","response_rank","unresolved_residual_ref"],"properties":{"event_id":{"type":"string","minLength":1},"strength":{"enum":["weak","medium","strong"]},"strength_rank":{"type":"integer","minimum":1,"maximum":3},"evidence_ref":{"type":"string","minLength":1},"response":{"enum":["annotate","block_promotion","downgrade_or_split"]},"response_rank":{"type":"integer","minimum":1,"maximum":3},"unresolved_residual_ref":{"type":"string","minLength":1}},"additionalProperties":false}},
    "revision":{"type":"object","required":["revision_id","action","superseded_claim_id","successor_claim_ids","prior_history_refs","unresolved_residual_refs"],"properties":{"revision_id":{"type":"string","minLength":1},"action":{"enum":["downgrade","split","supersede"]},"superseded_claim_id":{"type":"string","minLength":1},"successor_claim_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"prior_history_refs":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"unresolved_residual_refs":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}},"additionalProperties":false},
    "dependency_repair":{"type":"object","required":["seed_claim_id","declared_affected_claim_ids","repaired_claim_ids","repair_budget","repair_count"],"properties":{"seed_claim_id":{"type":"string","minLength":1},"declared_affected_claim_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"repaired_claim_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"repair_budget":{"type":"integer","minimum":1},"repair_count":{"type":"integer","minimum":1}},"additionalProperties":false},
    "ontology_migration":{"type":"object","required":["prior_version","new_version","migration_ref","identity_preserved"],"properties":{"prior_version":{"type":"string","minLength":1},"new_version":{"type":"string","minLength":1},"migration_ref":{"type":"string","minLength":1},"identity_preserved":{"type":"boolean"}},"additionalProperties":false},
    "restart_persistence":{"type":"object","required":["restart_generation","visible_claim_ids","visible_revision_ids","visible_residual_refs","observation_ref"],"properties":{"restart_generation":{"type":"integer","minimum":1},"visible_claim_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"visible_revision_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"visible_residual_refs":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"observation_ref":{"type":"string","minLength":1}},"additionalProperties":false},
    "decision":{"type":"object","required":["state","promotion_allowed","support_state_effect"],"properties":{"state":{"enum":["revised_with_residual","blocked","quarantined"]},"promotion_allowed":{"type":"boolean"},"support_state_effect":{"enum":["none","blocks_promotion","eligible_for_bounded_evidence_review"]}},"additionalProperties":false},
    "promotion_blockers":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"non_claims":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}
  },"additionalProperties":false
}
