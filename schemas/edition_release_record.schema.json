{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/edition_release_record.schema.json",
  "title": "Edition Release Record",
  "type": "object",
  "required": [
    "record_type",
    "release_id",
    "major_version",
    "source_commit",
    "source_tag",
    "edition_profile",
    "primary_audiences",
    "derivation_source",
    "artifact_formats",
    "validation_commands",
    "validation_status",
    "review_status",
    "human_consumption_gate",
    "audiobook_gate",
    "release_notes",
    "residuals",
    "non_claims"
  ],
  "properties": {
    "record_type": {
      "type": "string",
      "enum": ["edition_release"]
    },
    "release_id": { "type": "string", "minLength": 1 },
    "major_version": { "type": "string", "minLength": 1 },
    "source_commit": { "type": "string", "minLength": 1 },
    "source_tag": { "type": "string", "minLength": 1 },
    "edition_profile": {
      "type": "string",
      "enum": ["research_release", "reader_release", "audio_release"]
    },
    "primary_audiences": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ai_agents", "human_researchers", "interested_humans"]
      }
    },
    "derivation_source": { "type": "string", "minLength": 1 },
    "artifact_formats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["format", "status", "command_or_tool", "path_or_uri", "notes"],
        "properties": {
          "format": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": [
              "not_attempted",
              "pending",
              "rendered",
              "generated",
              "reviewed",
              "published",
              "failed",
              "not_applicable"
            ]
          },
          "command_or_tool": { "type": "string", "minLength": 1 },
          "path_or_uri": { "type": "string" },
          "notes": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "validation_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation_status": {
      "type": "string",
      "enum": ["pass", "fail", "partial", "pending"]
    },
    "review_status": {
      "type": "object",
      "required": [
        "reader_continuity_review",
        "source_scaffold_removed",
        "audio_script_review",
        "notes"
      ],
      "properties": {
        "reader_continuity_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "source_scaffold_removed": {
          "type": "string",
          "enum": ["not_required", "not_checked", "pass", "fail"]
        },
        "audio_script_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "reader_manuscript": {
      "type": "object",
      "required": ["source_dir", "status", "review_notes"],
      "properties": {
        "source_dir": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["not_required", "generated", "reviewed", "published", "failed"]
        },
        "review_notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "audio_package": {
      "type": "object",
      "required": ["script_dir", "status", "review_notes"],
      "properties": {
        "script_dir": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["not_required", "script_generated", "reviewed", "audio_generated", "published", "failed"]
        },
        "review_notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "companion_material": {
      "type": "object",
      "required": ["path_or_uri", "status", "review_notes"],
      "properties": {
        "path_or_uri": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["not_required", "not_started", "generated", "reviewed", "published", "failed"]
        },
        "review_notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "human_consumption_gate": {
      "type": "object",
      "required": [
        "reader_spine_review",
        "ebook_layout_review",
        "diagram_image_review",
        "bedtime_readability_review",
        "companion_notes_status",
        "notes"
      ],
      "properties": {
        "reader_spine_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "ebook_layout_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "diagram_image_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "bedtime_readability_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "companion_notes_status": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "audiobook_gate": {
      "type": "object",
      "required": [
        "script_review",
        "spoken_treatment_review",
        "chapter_marker_review",
        "audio_spot_check",
        "embedded_epub_check",
        "status",
        "notes"
      ],
      "properties": {
        "script_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "spoken_treatment_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "chapter_marker_review": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "audio_spot_check": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "embedded_epub_check": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "status": {
          "type": "string",
          "enum": ["not_required", "not_started", "in_progress", "pass", "fail"]
        },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "format_probe_closure": {
      "type": "object",
      "required": [
        "status",
        "curated_format_probe_manifest",
        "key_figure_format_probe_manifest",
        "epub_repaired_package_sha256",
        "epub_content_xhtml_entries_checked",
        "epub_unresolved_internal_hrefs",
        "docx_repaired_package_sha256",
        "docx_raw_qmd_relationship_targets",
        "docx_libreoffice_converted_pages",
        "docx_libreoffice_text_characters_checked",
        "docx_libreoffice_blank_pages",
        "docx_libreoffice_low_ink_pages",
        "docx_libreoffice_near_edge_pages",
        "pdf_pages_raster_rendered",
        "pdf_blank_raster_pages",
        "pdf_near_edge_raster_pages",
        "pdf_reading_flow_text_pages",
        "pdf_reading_flow_nonempty_text_pages",
        "pdf_reading_flow_chapter_headings",
        "pdf_reading_flow_appendix_headings",
        "pdf_reading_flow_replacement_characters",
        "key_figure_epub_matched_titles",
        "key_figure_docx_matched_stems",
        "key_figure_pdf_matched_captions",
        "key_figure_geometry_manifest",
        "key_figure_geometry_content_bounds",
        "key_figure_geometry_text_anchor_bounds",
        "key_figure_geometry_min_edge_margin",
        "key_figure_raster_manifest",
        "key_figure_raster_artifacts",
        "key_figure_raster_standard_dimensions",
        "key_figure_raster_min_opaque_percent",
        "key_figure_raster_min_luminance_std",
        "key_figure_raster_min_quantized_colors",
        "key_figure_epub_layout_manifest",
        "key_figure_epub_layout_xhtml_entries",
        "key_figure_epub_layout_page_view_pairs",
        "key_figure_epub_layout_failed_pairs",
        "key_figure_epub_layout_max_overflow",
        "key_figure_epub_layout_image_failures",
        "key_figure_pdf_layout_manifest",
        "key_figure_pdf_layout_caption_pages",
        "key_figure_pdf_layout_raster_pages",
        "key_figure_pdf_layout_min_caption_margin",
        "key_figure_pdf_layout_min_page_ink",
        "key_figure_pdf_layout_max_near_edge_ink",
        "key_figure_docx_layout_manifest",
        "key_figure_docx_layout_title_pages",
        "key_figure_docx_layout_raster_pages",
        "key_figure_docx_layout_min_title_margin",
        "key_figure_docx_layout_min_page_ink",
        "key_figure_docx_layout_max_near_edge_ink",
        "visual_identity_manifest",
        "visual_identity_colors",
        "visual_identity_non_neutral_families",
        "visual_identity_key_figures",
        "visual_identity_min_text_contrast",
        "reader_accessibility_navigation_manifest",
        "reader_accessibility_navigation_chapters",
        "reader_accessibility_navigation_h1",
        "reader_accessibility_navigation_handoffs",
        "reader_accessibility_navigation_fig_alts",
        "reader_accessibility_navigation_figure_boundaries",
        "reader_accessibility_navigation_live_marker_leaks",
        "reader_accessibility_navigation_raw_claim_leaks",
        "audio_reading_flow_script_files",
        "audio_reading_flow_ordered_markers",
        "audio_reading_flow_narration_notes",
        "audio_reading_flow_text_characters",
        "release_boundary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["automated_probe_passed_release_blocked"]
        },
        "curated_format_probe_manifest": { "type": "string", "minLength": 1 },
        "key_figure_format_probe_manifest": { "type": "string", "minLength": 1 },
        "epub_repaired_package_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "epub_content_xhtml_entries_checked": { "type": "integer", "minimum": 0 },
        "epub_unresolved_internal_hrefs": { "type": "integer", "minimum": 0 },
        "epub_browser_page_view_pairs": { "type": "integer", "minimum": 0 },
        "epub_browser_failed_page_view_pairs": { "type": "integer", "minimum": 0 },
        "docx_repaired_package_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "docx_raw_qmd_relationship_targets": { "type": "integer", "minimum": 0 },
        "docx_libreoffice_converted_pages": { "type": "integer", "minimum": 0 },
        "docx_libreoffice_text_characters_checked": { "type": "integer", "minimum": 0 },
        "docx_libreoffice_blank_pages": { "type": "integer", "minimum": 0 },
        "docx_libreoffice_low_ink_pages": { "type": "integer", "minimum": 0 },
        "docx_libreoffice_near_edge_pages": { "type": "integer", "minimum": 0 },
        "pdf_pages_raster_rendered": { "type": "integer", "minimum": 0 },
        "pdf_blank_raster_pages": { "type": "integer", "minimum": 0 },
        "pdf_near_edge_raster_pages": { "type": "integer", "minimum": 0 },
        "pdf_reading_flow_text_pages": { "type": "integer", "minimum": 0 },
        "pdf_reading_flow_nonempty_text_pages": { "type": "integer", "minimum": 0 },
        "pdf_reading_flow_chapter_headings": { "type": "integer", "minimum": 0 },
        "pdf_reading_flow_appendix_headings": { "type": "integer", "minimum": 0 },
        "pdf_reading_flow_replacement_characters": { "type": "integer", "minimum": 0 },
        "key_figure_epub_matched_titles": { "type": "integer", "minimum": 0 },
        "key_figure_docx_matched_stems": { "type": "integer", "minimum": 0 },
        "key_figure_pdf_matched_captions": { "type": "integer", "minimum": 0 },
        "key_figure_geometry_manifest": { "type": "string", "minLength": 1 },
        "key_figure_geometry_content_bounds": { "type": "integer", "minimum": 0 },
        "key_figure_geometry_text_anchor_bounds": { "type": "integer", "minimum": 0 },
        "key_figure_geometry_min_edge_margin": { "type": "number", "minimum": 0 },
        "key_figure_raster_manifest": { "type": "string", "minLength": 1 },
        "key_figure_raster_artifacts": { "type": "integer", "minimum": 0 },
        "key_figure_raster_standard_dimensions": { "type": "integer", "minimum": 0 },
        "key_figure_raster_min_opaque_percent": { "type": "number", "minimum": 0 },
        "key_figure_raster_min_luminance_std": { "type": "number", "minimum": 0 },
        "key_figure_raster_min_quantized_colors": { "type": "integer", "minimum": 0 },
        "key_figure_epub_layout_manifest": { "type": "string", "minLength": 1 },
        "key_figure_epub_layout_xhtml_entries": { "type": "integer", "minimum": 0 },
        "key_figure_epub_layout_page_view_pairs": { "type": "integer", "minimum": 0 },
        "key_figure_epub_layout_failed_pairs": { "type": "integer", "minimum": 0 },
        "key_figure_epub_layout_max_overflow": { "type": "integer", "minimum": 0 },
        "key_figure_epub_layout_image_failures": { "type": "integer", "minimum": 0 },
        "key_figure_pdf_layout_manifest": { "type": "string", "minLength": 1 },
        "key_figure_pdf_layout_caption_pages": { "type": "integer", "minimum": 0 },
        "key_figure_pdf_layout_raster_pages": { "type": "integer", "minimum": 0 },
        "key_figure_pdf_layout_min_caption_margin": { "type": "number", "minimum": 0 },
        "key_figure_pdf_layout_min_page_ink": { "type": "number", "minimum": 0 },
        "key_figure_pdf_layout_max_near_edge_ink": { "type": "number", "minimum": 0 },
        "key_figure_docx_layout_manifest": { "type": "string", "minLength": 1 },
        "key_figure_docx_layout_title_pages": { "type": "integer", "minimum": 0 },
        "key_figure_docx_layout_raster_pages": { "type": "integer", "minimum": 0 },
        "key_figure_docx_layout_min_title_margin": { "type": "number", "minimum": 0 },
        "key_figure_docx_layout_min_page_ink": { "type": "number", "minimum": 0 },
        "key_figure_docx_layout_max_near_edge_ink": { "type": "number", "minimum": 0 },
        "visual_identity_manifest": { "type": "string", "minLength": 1 },
        "visual_identity_colors": { "type": "integer", "minimum": 0 },
        "visual_identity_non_neutral_families": { "type": "integer", "minimum": 0 },
        "visual_identity_key_figures": { "type": "integer", "minimum": 0 },
        "visual_identity_min_text_contrast": { "type": "number", "minimum": 0 },
        "reader_accessibility_navigation_manifest": { "type": "string", "minLength": 1 },
        "reader_accessibility_navigation_chapters": { "type": "integer", "minimum": 0 },
        "reader_accessibility_navigation_h1": { "type": "integer", "minimum": 0 },
        "reader_accessibility_navigation_handoffs": { "type": "integer", "minimum": 0 },
        "reader_accessibility_navigation_fig_alts": { "type": "integer", "minimum": 0 },
        "reader_accessibility_navigation_figure_boundaries": { "type": "integer", "minimum": 0 },
        "reader_accessibility_navigation_live_marker_leaks": { "type": "integer", "minimum": 0 },
        "reader_accessibility_navigation_raw_claim_leaks": { "type": "integer", "minimum": 0 },
        "audio_reading_flow_script_files": { "type": "integer", "minimum": 0 },
        "audio_reading_flow_ordered_markers": { "type": "integer", "minimum": 0 },
        "audio_reading_flow_narration_notes": { "type": "integer", "minimum": 0 },
        "audio_reading_flow_text_characters": { "type": "integer", "minimum": 0 },
        "release_boundary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "release_notes": { "type": "string", "minLength": 1 },
    "residuals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "non_claims": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
