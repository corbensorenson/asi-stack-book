{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/claim_record.schema.json",
  "title": "Claim Record",
  "type": "object",
  "required": [
    "claim_id",
    "text",
    "claim_scope",
    "claim_label",
    "support_state",
    "lifecycle_state",
    "source_mapping_status",
    "source_mapping_refs",
    "evidence_readiness_state",
    "source_handles",
    "surface_refs",
    "tests",
    "uncertainty",
    "contradictions",
    "contradiction_state",
    "review_status",
    "revision_history_refs",
    "required_next_evidence",
    "promotion_blockers",
    "support_state_effect",
    "non_claims"
  ],
  "properties": {
    "claim_id": { "type": "string", "minLength": 1 },
    "text": { "type": "string", "minLength": 1 },
    "claim_scope": { "type": "string", "minLength": 1 },
    "claim_label": {
      "type": "string",
      "enum": [
        "Demonstrated",
        "Measured",
        "Mechanized",
        "Hypothesized",
        "Design rationale",
        "Speculative"
      ]
    },
    "support_state": {
      "type": "string",
      "enum": [
        "unsupported",
        "argument",
        "source-derived",
        "prototype-backed",
        "synthetic-test-backed",
        "empirical-test-backed",
        "external-literature-backed",
        "deprecated",
        "refuted"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "proposed",
        "recorded",
        "mapped",
        "challenged",
        "revised",
        "downgraded",
        "deprecated",
        "split",
        "merged",
        "promoted",
        "retired"
      ]
    },
    "source_mapping_status": {
      "type": "string",
      "enum": [
        "none",
        "source_note_mapped",
        "raw_passage_reviewed",
        "evidence_packet_mapped",
        "blocked",
        "deprecated"
      ]
    },
    "source_mapping_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_readiness_state": {
      "type": "string",
      "enum": [
        "not_ready",
        "shape_validated",
        "mapped_for_review",
        "ready_for_transition_review",
        "blocked",
        "deprecated"
      ]
    },
    "source_handles": { "type": "array", "items": { "type": "string" } },
    "surface_refs": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } },
    "uncertainty": { "type": "string", "minLength": 1 },
    "evidence_bundle": {
      "type": "object",
      "properties": {
        "source_hash": { "type": "string" },
        "code_revision": { "type": "string" },
        "environment_manifest": { "type": "string" },
        "baseline": { "type": "string" },
        "test_command": { "type": "string" },
        "metrics": { "type": "object", "additionalProperties": true },
        "raw_logs": { "type": "array", "items": { "type": "string" } },
        "negative_results": { "type": "array", "items": { "type": "string" } },
        "ablations": { "type": "array", "items": { "type": "string" } },
        "failure_reproduction": { "type": "string" },
        "artifacts": { "type": "array", "items": { "type": "string" } },
        "provenance": { "type": "string" },
        "conclusion": { "type": "string" },
        "limitations": { "type": "string" },
        "release_notes": { "type": "string" }
      },
      "additionalProperties": false,
      "default": {}
    },
    "contradictions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "contradiction_state": {
      "type": "string",
      "enum": ["none", "open", "bounded", "resolved", "refuted", "residualized"]
    },
    "review_status": { "type": "string", "enum": ["open", "reviewed", "blocked", "deprecated"] },
    "revision_history_refs": { "type": "array", "items": { "type": "string" } },
    "required_next_evidence": { "type": "array", "items": { "type": "string" } },
    "promotion_blockers": { "type": "array", "items": { "type": "string" } },
    "support_state_effect": {
      "type": "string",
      "enum": [
        "none",
        "record_shape_only",
        "argument_only",
        "eligible_for_bounded_evidence_review",
        "blocks_promotion"
      ]
    },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
