{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/deliberation_admission_result.schema.json",
  "title": "Deliberation Admission Result",
  "type": "object",
  "required": ["schema_version", "run_date", "fixture_path", "fixture_sha256", "case_results", "route_counts", "lean_bridge", "support_state_effect", "known_extra_compute_harms_preserved", "limitations", "non_claims"],
  "properties": {
    "schema_version": {"const": "asi_stack.deliberation_admission_result.v0"}, "run_date": {"const": "2026-07-13"},
    "fixture_path": {"const": "experiments/deliberation_admission/fixtures/cases.json"}, "fixture_sha256": {"pattern": "^[0-9a-f]{64}$"},
    "case_results": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"type": "object", "required": ["id", "expected_route", "actual_route", "passed"], "properties": {"id": {"type": "string"}, "expected_route": {"type": "string"}, "actual_route": {"type": "string"}, "passed": {"const": true}}, "additionalProperties": false}},
    "route_counts": {"type": "object", "minProperties": 3, "additionalProperties": {"type": "integer", "minimum": 1}},
    "lean_bridge": {"type": "object", "required": ["module", "source", "theorems", "build_command"], "properties": {"module": {"const": "AsiStackProofs.DeliberationRefinement"}, "source": {"const": "lean/AsiStackProofs/DeliberationRefinement.lean"}, "theorems": {"type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true, "items": {"type": "string"}}, "build_command": {"const": "cd lean && lake build AsiStackProofs.DeliberationRefinement"}}, "additionalProperties": false},
    "support_state_effect": {"const": "none"}, "known_extra_compute_harms_preserved": {"const": 15},
    "limitations": {"type": "array", "minItems": 5, "items": {"type": "string"}}, "non_claims": {"type": "array", "minItems": 6, "items": {"type": "string"}}
  }, "additionalProperties": false
}
