{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asi-stack.local/schemas/p2_resource_ceiling.schema.json",
  "title": "P2 frozen resource ceiling",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "recorded_date", "state", "claim_id", "scope", "host_receipt", "per_container_hard_limits", "task_acceptance_ceilings", "campaign_ceilings", "measurement_contract", "empirical_basis", "headroom_rationale", "qualification_state", "support_state_effect", "release_effect", "non_claims"],
  "properties": {
    "schema_version": {"const": "asi_stack.p2_resource_ceiling.v2"},
    "recorded_date": {"const": "2026-07-17"},
    "state": {"const": "measurement_semantics_repaired_v2_frozen_before_candidate_outcomes"},
    "claim_id": {"const": "p2.governed_natural_repository_change_admission_joint_frontier"},
    "scope": {"const": "development_and_replacement_resource_competence"},
    "host_receipt": {"type": "object"},
    "per_container_hard_limits": {"type": "object"},
    "task_acceptance_ceilings": {"type": "object"},
    "campaign_ceilings": {"type": "object"},
    "measurement_contract": {"type": "object"},
    "empirical_basis": {"type": "object"},
    "headroom_rationale": {"type": "object"},
    "qualification_state": {
      "type": "object",
      "required": ["ceiling_frozen", "replacement_draw_started", "all_qualified_tasks_remeasured", "resource_gate_passed", "final_pool_selected", "final_pool_opened"],
      "properties": {
        "ceiling_frozen": {"const": true},
        "replacement_draw_started": {"const": true},
        "all_qualified_tasks_remeasured": {"const": false},
        "resource_gate_passed": {"const": false},
        "final_pool_selected": {"const": false},
        "final_pool_opened": {"const": false}
      }
    },
    "support_state_effect": {"const": "none"},
    "release_effect": {"const": "none"},
    "non_claims": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 20}}
  }
}
