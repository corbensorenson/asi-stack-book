{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/agency_rights_checklist.schema.json",
  "title": "Agency Rights Checklist",
  "type": "object",
  "required": [
    "plan_id",
    "affected_parties",
    "delegation_scope",
    "manipulation_risk",
    "reversibility",
    "review_channel",
    "appeal_channel",
    "shutdown_or_rollback_path",
    "accountable_principal",
    "residual_dependency_risk",
    "approval_required"
  ],
  "properties": {
    "plan_id": { "type": "string", "minLength": 1 },
    "affected_parties": { "type": "array", "items": { "type": "string" } },
    "delegation_scope": { "type": "string", "minLength": 1 },
    "manipulation_risk": { "type": "string", "minLength": 1 },
    "reversibility": { "type": "string", "minLength": 1 },
    "review_channel": { "type": "string", "minLength": 1 },
    "appeal_channel": { "type": "string", "minLength": 1 },
    "shutdown_or_rollback_path": { "type": "string", "minLength": 1 },
    "accountable_principal": { "type": "string", "minLength": 1 },
    "residual_dependency_risk": { "type": "array", "items": { "type": "string" } },
    "approval_required": { "type": "boolean" }
  },
  "additionalProperties": false
}
