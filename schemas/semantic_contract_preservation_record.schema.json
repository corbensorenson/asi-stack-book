{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/semantic_contract_preservation_record.schema.json",
  "title": "Semantic Contract Preservation Record",
  "type": "object",
  "required": ["record_id", "source_ids", "source_contract", "ambiguity_ledger", "field_lineage", "semantic_ir", "pass_bundle", "target_contract", "preservation_obligations", "repair", "digest_parity", "decision", "promotion_blockers", "non_claims"],
  "properties": {
    "record_id": {"type": "string", "minLength": 1},
    "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "source_contract": {
      "type": "object",
      "required": ["contract_id", "fields", "requirements", "authority_refs"],
      "properties": {
        "contract_id": {"type": "string", "minLength": 1},
        "fields": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "requirements": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "authority_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "ambiguity_ledger": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ambiguity_id", "source_field", "state", "resolution_ref", "strict_compile_effect"],
        "properties": {
          "ambiguity_id": {"type": "string", "minLength": 1},
          "source_field": {"type": "string", "minLength": 1},
          "state": {"enum": ["resolved", "unresolved", "deferred", "not_applicable"]},
          "resolution_ref": {"type": ["string", "null"]},
          "strict_compile_effect": {"enum": ["allow", "block", "escalate"]}
        },
        "additionalProperties": false
      }
    },
    "field_lineage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_field", "ir_field", "target_field", "transform", "authority_refs", "ambiguity_refs"],
        "properties": {
          "source_field": {"type": "string", "minLength": 1},
          "ir_field": {"type": "string", "minLength": 1},
          "target_field": {"type": "string", "minLength": 1},
          "transform": {"enum": ["identity", "normalized", "split", "merged", "paraphrased", "omitted", "inserted"]},
          "authority_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "ambiguity_refs": {"type": "array", "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": false
      }
    },
    "semantic_ir": {
      "type": "object",
      "required": ["ir_id", "node_ids", "obligation_refs", "authority_refs", "ambiguity_refs"],
      "properties": {
        "ir_id": {"type": "string", "minLength": 1},
        "node_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "obligation_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "authority_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "ambiguity_refs": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "pass_bundle": {
      "type": "object",
      "required": ["pass_id", "input_ref", "output_ref", "input_digest", "output_digest", "semantic_validator_ref", "validator_result", "failure_refs", "authority_preserved"],
      "properties": {
        "pass_id": {"type": "string", "minLength": 1},
        "input_ref": {"type": "string", "minLength": 1},
        "output_ref": {"type": "string", "minLength": 1},
        "input_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "output_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "semantic_validator_ref": {"type": ["string", "null"]},
        "validator_result": {"enum": ["pass", "fail", "abstain", "not_attempted"]},
        "failure_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "authority_preserved": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "target_contract": {
      "type": "object",
      "required": ["target_id", "fields", "requirement_refs", "authority_refs", "artifact_ref"],
      "properties": {
        "target_id": {"type": "string", "minLength": 1},
        "fields": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "requirement_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "authority_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "artifact_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "preservation_obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["requirement_ref", "ir_node_ref", "target_field", "semantic_validator_ref", "status"],
        "properties": {
          "requirement_ref": {"type": "string", "minLength": 1},
          "ir_node_ref": {"type": "string", "minLength": 1},
          "target_field": {"type": "string", "minLength": 1},
          "semantic_validator_ref": {"type": ["string", "null"]},
          "status": {"enum": ["preserved", "violated", "unverified", "deferred"]}
        },
        "additionalProperties": false
      }
    },
    "repair": {
      "type": "object",
      "required": ["failed_node_refs", "declared_scope", "actual_mutation_refs", "blast_radius_refs", "repair_receipt_ref", "post_repair_validator_result"],
      "properties": {
        "failed_node_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "declared_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "actual_mutation_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "blast_radius_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "repair_receipt_ref": {"type": "string", "minLength": 1},
        "post_repair_validator_result": {"enum": ["pass", "fail", "abstain", "not_attempted"]}
      },
      "additionalProperties": false
    },
    "digest_parity": {
      "type": "object",
      "required": ["digest_equal", "semantic_preservation_claim_allowed", "semantic_validator_ref"],
      "properties": {
        "digest_equal": {"type": "boolean"},
        "semantic_preservation_claim_allowed": {"type": "boolean"},
        "semantic_validator_ref": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["compile_state", "strict_execution_allowed", "support_state_effect"],
      "properties": {
        "compile_state": {"enum": ["accepted", "blocked", "repair_required", "abstained"]},
        "strict_execution_allowed": {"type": "boolean"},
        "support_state_effect": {"enum": ["none", "blocks_promotion", "eligible_for_bounded_evidence_review"]}
      },
      "additionalProperties": false
    },
    "promotion_blockers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false
}
