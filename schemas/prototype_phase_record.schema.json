{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/prototype_phase_record.schema.json",
  "title": "Prototype Phase Record",
  "type": "object",
  "required": [
    "phase_id",
    "phase_name",
    "unlocks",
    "required_artifacts",
    "acceptance_gates",
    "blocked_by",
    "validation_commands",
    "evidence_refs",
    "non_claims",
    "status"
  ],
  "properties": {
    "phase_id": { "type": "string", "minLength": 1 },
    "phase_name": { "type": "string", "minLength": 1 },
    "unlocks": { "type": "array", "items": { "type": "string" } },
    "required_artifacts": { "type": "array", "items": { "type": "string" } },
    "acceptance_gates": { "type": "array", "items": { "type": "string" } },
    "blocked_by": { "type": "array", "items": { "type": "string" } },
    "validation_commands": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "non_claims": { "type": "array", "items": { "type": "string" } },
    "status": {
      "type": "string",
      "enum": ["proposed", "active", "complete", "blocked", "deferred"]
    }
  },
  "additionalProperties": false
}
