{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/costed_route_record.schema.json",
  "title": "Costed Route Record",
  "type": "object",
  "required": [
    "task_id",
    "route_state",
    "task_contract_ref",
    "quality_predicate",
    "authority_ceiling",
    "candidate_routes",
    "selected_route",
    "rejected_lower_cost_routes",
    "verification_result",
    "outcome_state",
    "cost_accounting",
    "cost_classes",
    "hidden_cost_checks",
    "residual_obligations",
    "fallback_route",
    "promotion_candidate",
    "support_state_effect",
    "non_claims"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "route_state": {
      "type": "string",
      "enum": ["proposed", "candidate", "evaluated", "fallback_required", "blocked", "retired"]
    },
    "task_contract_ref": { "type": "string", "minLength": 1 },
    "quality_predicate": { "type": "string", "minLength": 1 },
    "authority_ceiling": { "type": "string", "minLength": 1 },
    "candidate_routes": { "type": "array", "items": { "type": "string" } },
    "selected_route": { "type": "string", "minLength": 1 },
    "rejected_lower_cost_routes": { "type": "array", "items": { "type": "string" } },
    "verification_result": {
      "type": "string",
      "enum": ["not_run", "pass", "fail", "partial"]
    },
    "outcome_state": {
      "type": "string",
      "enum": ["not_evaluated", "adequate_minimum", "adequate_overkill", "cheap_brittle", "hidden_cost", "unsafe_saving"]
    },
    "cost_accounting": {
      "type": "object",
      "required": ["estimated_tokens", "estimated_time_seconds", "tool_cost_units"],
      "properties": {
        "estimated_tokens": { "type": "number" },
        "estimated_time_seconds": { "type": "number" },
        "tool_cost_units": { "type": "number" }
      },
      "additionalProperties": false
    },
    "cost_classes": { "type": "array", "items": { "type": "string" } },
    "hidden_cost_checks": { "type": "array", "items": { "type": "string" } },
    "residual_obligations": { "type": "array", "items": { "type": "string" } },
    "fallback_route": { "type": "string", "minLength": 1 },
    "promotion_candidate": { "type": "boolean" },
    "support_state_effect": {
      "type": "string",
      "enum": [
        "none",
        "record_shape_only",
        "argument_only",
        "eligible_for_bounded_evidence_review",
        "blocks_promotion"
      ]
    },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
