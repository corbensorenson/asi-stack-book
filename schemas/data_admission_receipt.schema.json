{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Admission Receipt",
  "type": "object",
  "required": [
    "receipt_id",
    "dataset_ref",
    "provenance_class",
    "origin_refs",
    "license_or_authority_ref",
    "admission_mode",
    "synthetic_lineage_refs",
    "split_exclusion_refs",
    "contamination_check_refs",
    "retention_policy",
    "deletion_scope",
    "evaluation_refs",
    "residuals",
    "promotion_decision",
    "support_state_effect",
    "non_claims"
  ],
  "properties": {
    "receipt_id": { "type": "string", "minLength": 1 },
    "dataset_ref": { "type": "string", "minLength": 1 },
    "provenance_class": { "type": "string", "minLength": 1 },
    "origin_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "license_or_authority_ref": { "type": "string", "minLength": 1 },
    "admission_mode": { "type": "string", "enum": ["real", "synthetic", "mixed", "quarantine"] },
    "synthetic_lineage_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "split_exclusion_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "contamination_check_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "retention_policy": { "type": "string", "minLength": 1 },
    "deletion_scope": { "type": "string", "minLength": 1 },
    "evaluation_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "residuals": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "promotion_decision": { "type": "string", "enum": ["block", "quarantine", "experimental_only", "admit"] },
    "support_state_effect": { "type": "string", "minLength": 1 },
    "non_claims": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
