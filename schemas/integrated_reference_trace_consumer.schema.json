{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Integrated reference trace consumer result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "experiment_id", "status", "source_result_sha256",
    "corpus_sha256", "lean_model_sha256", "case_count",
    "accepted_case_count", "rejected_case_count", "accepted_event_count",
    "effect_attempt_count", "final_net_effect_count",
    "final_acknowledged_effect_count", "final_open_residual_count",
    "terminal_receipt_count", "rolled_back_case_count",
    "quarantined_case_count", "support_transition_count", "mutation_count",
    "mutation_rejection_count", "source_scenario_count", "receipts",
    "support_state_effect", "non_claims"
  ],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "experiment_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["passed", "failed"]},
    "source_result_sha256": {"type": "string", "minLength": 64},
    "corpus_sha256": {"type": "string", "minLength": 64},
    "lean_model_sha256": {"type": "string", "minLength": 64},
    "case_count": {"type": "integer"},
    "accepted_case_count": {"type": "integer"},
    "rejected_case_count": {"type": "integer"},
    "accepted_event_count": {"type": "integer"},
    "effect_attempt_count": {"type": "integer"},
    "final_net_effect_count": {"type": "integer"},
    "final_acknowledged_effect_count": {"type": "integer"},
    "final_open_residual_count": {"type": "integer"},
    "terminal_receipt_count": {"type": "integer"},
    "rolled_back_case_count": {"type": "integer"},
    "quarantined_case_count": {"type": "integer"},
    "support_transition_count": {"type": "integer"},
    "mutation_count": {"type": "integer"},
    "mutation_rejection_count": {"type": "integer"},
    "source_scenario_count": {"type": "integer"},
    "receipts": {"type": "array", "minItems": 18, "items": {"type": "object"}},
    "support_state_effect": {"type": "string", "enum": ["none"]},
    "non_claims": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 1}}
  }
}
