{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://corbensorenson.github.io/asi-stack-book/schemas/concurrent_effect_ledger_result.schema.json",
  "title":"Concurrent Effect Ledger Result",
  "type":"object","additionalProperties":false,
  "required":["schema_version","result_id","corpus_sha256","source_result_sha256","lean_model_sha256","case_count","accepted_case_count","rejected_case_count","accepted_event_count","unique_effect_attempt_count","acknowledged_effect_count","compensated_effect_count","residualized_effect_count","revocation_count","mutation_count","mutation_rejection_count","receipts","support_state_effect","non_claims"],
  "properties":{
    "schema_version":{"const":"asi_stack.concurrent_effect_ledger_result.v1"},"result_id":{"type":"string"},
    "corpus_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"source_result_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"lean_model_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},
    "case_count":{"const":16},"accepted_case_count":{"const":4},"rejected_case_count":{"const":12},"accepted_event_count":{"const":17},
    "unique_effect_attempt_count":{"const":5},"acknowledged_effect_count":{"const":3},"compensated_effect_count":{"const":1},"residualized_effect_count":{"const":1},"revocation_count":{"const":1},
    "mutation_count":{"const":12},"mutation_rejection_count":{"const":12},
    "receipts":{"type":"array","minItems":16,"maxItems":16,"items":{"type":"object"}},
    "support_state_effect":{"const":"none"},"non_claims":{"type":"array","minItems":3,"items":{"type":"string","minLength":1}}
  }
}
