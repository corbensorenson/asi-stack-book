{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asi-stack.local/schemas/post_v2_3_reader_html_release_record.schema.json",
  "title": "ASI Stack v2.0 curated-reader HTML release record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "release_id",
    "edition_id",
    "decision",
    "decision_date",
    "source_authority",
    "artifact",
    "inspection_evidence",
    "review_boundaries",
    "rights_snapshot",
    "approved_formats",
    "deferred_formats",
    "selected_format_blockers",
    "residuals",
    "support_state_effect",
    "non_claims"
  ],
  "properties": {
    "schema_version": {"const": "asi_stack.curated_reader_html_release_record.v2"},
    "record_type": {"const": "edition_release"},
    "release_id": {"type": "string", "minLength": 16},
    "edition_id": {"const": "asi-stack-curated-reader-v2.0"},
    "decision": {"const": "approved_exact_local_html_archive"},
    "decision_date": {"const": "2026-07-13"},
    "source_authority": {"type": "object"},
    "artifact": {"type": "object"},
    "inspection_evidence": {"type": "object"},
    "review_boundaries": {"type": "object"},
    "rights_snapshot": {"type": "object"},
    "approved_formats": {"const": ["canonical_curated_html"]},
    "deferred_formats": {"const": ["epub", "docx", "pdf", "audio", "embedded_audio"]},
    "selected_format_blockers": {"const": []},
    "residuals": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 12}},
    "support_state_effect": {"const": "none"},
    "non_claims": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 12}}
  }
}
