{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/virtual_context_refinement.schema.json",
  "title": "Virtual Context Refinement Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","result_id","source_sha256","resolver_scenario_count","resolver_valid_count","resolver_invalid_count","resolver_receipts","admission_fixture_count","admission_valid_fixture_count","admission_invalid_fixture_count","admission_suite_passed","materialization_trace_event_count","mandatory_miss_trace_event_count","materialization_final_state","mandatory_miss_final_state","mutation_count","mutation_rejection_count","mutation_receipts","support_state_effect","non_claims"],
  "properties": {
    "schema_version": {"const": "asi_stack.virtual_context_refinement.v1"},
    "result_id": {"const": "virtual-context-refinement-2026-07-15-local"},
    "source_sha256": {"type":"object","additionalProperties":false,"required":["lean_model","prior_resolver_result","admission_fixture_inventory","admission_validator"],"properties":{"lean_model":{"type":"string","pattern":"^[0-9a-f]{64}$"},"prior_resolver_result":{"type":"string","pattern":"^[0-9a-f]{64}$"},"admission_fixture_inventory":{"type":"string","pattern":"^[0-9a-f]{64}$"},"admission_validator":{"type":"string","pattern":"^[0-9a-f]{64}$"}}},
    "resolver_scenario_count": {"const":11}, "resolver_valid_count":{"const":2}, "resolver_invalid_count":{"const":9},
    "resolver_receipts":{"type":"array","minItems":11,"maxItems":11,"items":{"type":"object","additionalProperties":false,"required":["scenario_id","expected_valid","independently_matched","route"],"properties":{"scenario_id":{"type":"string","minLength":1},"expected_valid":{"type":"boolean"},"independently_matched":{"const":true},"route":{"type":"string","minLength":1}}}},
    "admission_fixture_count":{"const":8}, "admission_valid_fixture_count":{"const":3}, "admission_invalid_fixture_count":{"const":5}, "admission_suite_passed":{"const":true},
    "materialization_trace_event_count":{"const":4}, "mandatory_miss_trace_event_count":{"const":2}, "materialization_final_state":{"type":"object"}, "mandatory_miss_final_state":{"type":"object"},
    "mutation_count":{"const":55}, "mutation_rejection_count":{"const":55},
    "mutation_receipts":{"type":"array","minItems":55,"maxItems":55,"items":{"type":"object","additionalProperties":false,"required":["mutation_id","rejected","failed_event_index","reasons"],"properties":{"mutation_id":{"type":"string","minLength":1},"rejected":{"const":true},"failed_event_index":{"type":"integer","minimum":0,"maximum":3},"reasons":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}}}},
    "support_state_effect":{"const":"none"}, "non_claims":{"type":"array","minItems":3,"items":{"type":"string","minLength":1}}
  }
}
