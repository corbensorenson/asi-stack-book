{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/post_v2_1_empirical_outcomes.schema.json",
  "title": "Post-v2.1 Empirical Outcome Ledger",
  "type": "object",
  "required": ["schema_version", "outcome_set_id", "recorded_date", "preregistration_ref", "setup_commit", "input_bundles", "execution_accounting", "statistics_boundary", "P1", "P2", "P3", "overall_disposition", "support_state_effect", "non_claims", "bundle_sha256"],
  "properties": {
    "schema_version": {"const": "asi_stack.post_v2_1_empirical_outcomes.v0"},
    "outcome_set_id": {"const": "post-v2-1-empirical-outcomes-2026-07-11"},
    "recorded_date": {"const": "2026-07-11"},
    "preregistration_ref": {"const": "experiments/post_v2_1_evidence_program/preregistration.json"},
    "setup_commit": {"const": "707fc10969b04bd31e135c8a711b33e9505e0d87"},
    "input_bundles": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"type": "object", "required": ["path", "bundle_sha256"], "properties": {"path": {"type": "string"}, "bundle_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false}},
    "execution_accounting": {"type": "object", "required": ["model_calls", "registered_model_call_ceiling", "retries", "outcome_driven_arm_expansions", "programs_completed"], "properties": {"model_calls": {"const": 332}, "registered_model_call_ceiling": {"const": 332}, "retries": {"const": 0}, "outcome_driven_arm_expansions": {"const": 0}, "programs_completed": {"const": 3}}, "additionalProperties": false},
    "statistics_boundary": {"type": "string", "minLength": 80},
    "P1": {"$ref": "#/$defs/program"},
    "P2": {"$ref": "#/$defs/program"},
    "P3": {"$ref": "#/$defs/program"},
    "overall_disposition": {"const": "reconcile_bounded_results_without_core_promotion"},
    "support_state_effect": {"const": "none"},
    "non_claims": {"type": "array", "minItems": 6, "items": {"type": "string", "minLength": 1}},
    "bundle_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "program": {
      "type": "object",
      "required": ["support_state_effect", "residual_dispositions", "finding"],
      "properties": {
        "support_state_effect": {"const": "no_core_promotion"},
        "residual_dispositions": {"type": "object", "minProperties": 3, "additionalProperties": {"enum": ["closed", "narrowed", "persisted", "escalated"]}},
        "finding": {"type": "string", "minLength": 100}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
