{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/formal_semantic_depth_record.schema.json",
  "title": "Formal Semantic-Depth Record",
  "type": "object",
  "required": ["record_id", "source_ids", "claim_boundary", "abstraction_map", "assumptions", "depth_lanes", "by_construction_properties", "excluded_runtime_behavior", "implementation_binding", "consumer_decision", "promotion_blockers", "non_claims"],
  "properties": {
    "record_id": {"type": "string", "minLength": 1},
    "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "claim_boundary": {
      "type": "object",
      "required": ["claim_id", "prose_predicate", "formal_predicate", "scope"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "prose_predicate": {"type": "string", "minLength": 1},
        "formal_predicate": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "abstraction_map": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["prose_term", "formal_symbol", "representation", "losses"],
        "properties": {
          "prose_term": {"type": "string", "minLength": 1},
          "formal_symbol": {"type": "string", "minLength": 1},
          "representation": {"type": "string", "minLength": 1},
          "losses": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": false
      }
    },
    "assumptions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["assumption_id", "class", "statement", "discharge_state"],
        "properties": {
          "assumption_id": {"type": "string", "minLength": 1},
          "class": {"enum": ["clock", "concurrency", "event_completeness", "adversarial_log", "identity", "environment"]},
          "statement": {"type": "string", "minLength": 1},
          "discharge_state": {"enum": ["modeled", "externally_required", "unresolved"]}
        },
        "additionalProperties": false
      }
    },
    "depth_lanes": {
      "type": "array", "minItems": 5,
      "items": {
        "type": "object",
        "required": ["lane", "artifact_refs", "verifier_ref", "result", "semantic_binding", "authorized_statement"],
        "properties": {
          "lane": {"enum": ["field_presence", "finite_route", "derived_invariant", "executable_model_bridge", "implementation_binding"]},
          "artifact_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "verifier_ref": {"type": ["string", "null"]},
          "result": {"enum": ["passed", "failed", "blocked", "absent"]},
          "semantic_binding": {"enum": ["present", "partial", "absent"]},
          "authorized_statement": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "by_construction_properties": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "excluded_runtime_behavior": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "implementation_binding": {
      "type": "object",
      "required": ["state", "artifact_refs", "verifier_ref", "observed_runtime_refs", "limitations"],
      "properties": {
        "state": {"enum": ["bound_and_observed", "artifact_bound_not_observed", "unbound", "not_applicable"]},
        "artifact_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "verifier_ref": {"type": ["string", "null"]},
        "observed_runtime_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "consumer_decision": {
      "type": "object",
      "required": ["semantic_adequacy", "runtime_claim_allowed", "support_state_effect"],
      "properties": {
        "semantic_adequacy": {"enum": ["adequate_for_finite_predicate", "partial", "inadequate", "unreviewed"]},
        "runtime_claim_allowed": {"type": "boolean"},
        "support_state_effect": {"enum": ["none", "blocks_promotion", "eligible_for_bounded_evidence_review"]}
      },
      "additionalProperties": false
    },
    "promotion_blockers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false
}
