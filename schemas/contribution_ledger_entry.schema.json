{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/contribution_ledger_entry.schema.json",
  "title": "Contribution Ledger Entry",
  "type": "object",
  "required": [
    "entry_id",
    "contributor_id",
    "work_contract_id",
    "artifact_refs",
    "authorship_credit",
    "review_credit",
    "evidence_credit",
    "compensation_ref",
    "reputation_signal",
    "governance_effect",
    "conflict_notes",
    "recorded_by",
    "non_claims"
  ],
  "properties": {
    "entry_id": { "type": "string", "minLength": 1 },
    "contributor_id": { "type": "string", "minLength": 1 },
    "work_contract_id": { "type": "string", "minLength": 1 },
    "artifact_refs": { "type": "array", "items": { "type": "string" } },
    "authorship_credit": { "type": "string", "minLength": 1 },
    "review_credit": { "type": "string", "minLength": 1 },
    "evidence_credit": { "type": "string", "minLength": 1 },
    "compensation_ref": { "type": "string", "minLength": 1 },
    "reputation_signal": { "type": "string", "minLength": 1 },
    "governance_effect": { "type": "string", "minLength": 1 },
    "conflict_notes": { "type": "string", "minLength": 1 },
    "recorded_by": { "type": "string", "minLength": 1 },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
