{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asi-stack.example/schemas/p4_m7_update_unlearning_result.schema.json",
  "title": "P4 M7 Update and Unlearning Result",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "protocol_outcome",
    "claim_outcome",
    "corpus_sha256",
    "preregistration_sha256",
    "raw_run_sha256",
    "feature_artifact_sha256",
    "candidate_and_checkpoint_bytes_closed_before_axis_evaluation",
    "seeds",
    "arms",
    "claim_axes",
    "seed_results",
    "arm_summaries",
    "axis_dispositions",
    "storage_receipt",
    "lineage_receipt",
    "evaluator_recomputation_disagreement_count",
    "gate_checks_before_validator_mutations",
    "cost",
    "claim_ceiling",
    "support_state_effect",
    "chapter_core_promotion_count",
    "non_claims"
  ],
  "properties": {
    "schema_version": {"const": "asi_stack.p4_m7_confirmatory_result.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "protocol_outcome": {"const": "instrument_adequate_bounded_local_axis_separation"},
    "claim_outcome": {"const": "support_retained_with_bounded_noncore_axis_result"},
    "corpus_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "preregistration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "raw_run_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "feature_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "candidate_and_checkpoint_bytes_closed_before_axis_evaluation": {"const": true},
    "seeds": {"type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true, "items": {"type": "integer"}},
    "arms": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"type": "string"}},
    "claim_axes": {"type": "array", "minItems": 8, "maxItems": 8, "uniqueItems": true, "items": {"type": "string"}},
    "seed_results": {"type": "array", "minItems": 5, "maxItems": 5},
    "arm_summaries": {"type": "object"},
    "axis_dispositions": {"type": "object", "minProperties": 8, "maxProperties": 8},
    "storage_receipt": {"type": "object"},
    "lineage_receipt": {"type": "object"},
    "evaluator_recomputation_disagreement_count": {"const": 0},
    "gate_checks_before_validator_mutations": {"type": "object", "minProperties": 9, "maxProperties": 9},
    "cost": {"type": "object"},
    "claim_ceiling": {"type": "string", "minLength": 80},
    "support_state_effect": {"const": "none"},
    "chapter_core_promotion_count": {"const": 0},
    "non_claims": {"type": "array", "minItems": 5, "items": {"type": "string"}}
  },
  "additionalProperties": true
}
