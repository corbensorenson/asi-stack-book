{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/cyclic_memory_contract.schema.json",
  "title": "Cyclic Memory Contract",
  "type": "object",
  "required": [
    "contract_id",
    "memory_target",
    "memory_authority_scope",
    "vcm_packet_refs",
    "slot_count",
    "residue_policy",
    "winding_policy",
    "state_carry_boundary",
    "freshness_window",
    "stale_read_policy",
    "coverage_claim",
    "recurrence_schedule",
    "loop_exit_condition",
    "fallback_attention",
    "admission_state",
    "baseline_refs",
    "probe_requirements",
    "authority_non_widening",
    "residuals",
    "non_claims",
    "evidence_refs"
  ],
  "properties": {
    "contract_id": { "type": "string", "minLength": 1 },
    "memory_target": { "type": "string", "minLength": 1 },
    "memory_authority_scope": { "type": "string", "minLength": 1 },
    "vcm_packet_refs": { "type": "array", "items": { "type": "string" } },
    "slot_count": { "type": "number" },
    "residue_policy": { "type": "string", "minLength": 1 },
    "winding_policy": { "type": "string", "minLength": 1 },
    "state_carry_boundary": { "type": "string", "minLength": 1 },
    "freshness_window": { "type": "string", "minLength": 1 },
    "stale_read_policy": { "type": "string", "minLength": 1 },
    "coverage_claim": { "type": "string", "minLength": 1 },
    "recurrence_schedule": { "type": "string", "minLength": 1 },
    "loop_exit_condition": { "type": "string", "minLength": 1 },
    "fallback_attention": { "type": "string", "minLength": 1 },
    "admission_state": {
      "type": "string",
      "enum": [
        "structural_guardrail",
        "inadmissible_for_task",
        "fallback_required",
        "residualized",
        "eligible_for_workload_evaluation",
        "blocked"
      ]
    },
    "baseline_refs": { "type": "array", "items": { "type": "string" } },
    "probe_requirements": { "type": "array", "items": { "type": "string" } },
    "authority_non_widening": { "type": "string", "minLength": 1 },
    "residuals": { "type": "array", "items": { "type": "string" } },
    "non_claims": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
