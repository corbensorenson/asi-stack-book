{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/governed_repository_change_result.schema.json",
  "title": "Governed Repository Change Slice Result",
  "type": "object",
  "required": [
    "schema_version",
    "result_id",
    "recorded_date",
    "result_kind",
    "workload_ref",
    "workload_id",
    "scenario_count",
    "baseline_summary",
    "governed_summary",
    "matched_comparison",
    "scenario_results",
    "trace_invariants",
    "support_state_effect",
    "evidence_transition_created",
    "non_claims"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["asi_stack.governed_repository_change_result.v0"] },
    "result_id": { "type": "string", "minLength": 1 },
    "recorded_date": { "type": "string", "minLength": 1 },
    "result_kind": { "type": "string", "enum": ["executed_local_repository_change_comparison"] },
    "workload_ref": { "type": "string", "minLength": 1 },
    "workload_id": { "type": "string", "minLength": 1 },
    "scenario_count": { "type": "integer", "minimum": 1 },
    "baseline_summary": {
      "type": "object",
      "required": ["releases", "false_accepts", "false_rejects", "unsafe_effects_observed", "unsafe_releases", "correct_dispositions", "cost_units", "latency_steps", "operator_review_steps"],
      "properties": {
        "releases": { "type": "integer", "minimum": 0 },
        "false_accepts": { "type": "integer", "minimum": 0 },
        "false_rejects": { "type": "integer", "minimum": 0 },
        "unsafe_effects_observed": { "type": "integer", "minimum": 0 },
        "unsafe_releases": { "type": "integer", "minimum": 0 },
        "correct_dispositions": { "type": "integer", "minimum": 0 },
        "cost_units": { "type": "integer", "minimum": 0 },
        "latency_steps": { "type": "integer", "minimum": 0 },
        "operator_review_steps": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "governed_summary": {
      "type": "object",
      "required": ["releases", "refusals", "quarantines", "false_accepts", "false_rejects", "unsafe_effects_observed", "unsafe_releases", "correct_dispositions", "cost_units", "latency_steps", "operator_review_steps", "rollback_attempts", "exact_rollbacks", "failed_rollbacks", "residuals_discovered"],
      "properties": {
        "releases": { "type": "integer", "minimum": 0 },
        "refusals": { "type": "integer", "minimum": 0 },
        "quarantines": { "type": "integer", "minimum": 0 },
        "false_accepts": { "type": "integer", "minimum": 0 },
        "false_rejects": { "type": "integer", "minimum": 0 },
        "unsafe_effects_observed": { "type": "integer", "minimum": 0 },
        "unsafe_releases": { "type": "integer", "minimum": 0 },
        "correct_dispositions": { "type": "integer", "minimum": 0 },
        "cost_units": { "type": "integer", "minimum": 0 },
        "latency_steps": { "type": "integer", "minimum": 0 },
        "operator_review_steps": { "type": "integer", "minimum": 0 },
        "rollback_attempts": { "type": "integer", "minimum": 0 },
        "exact_rollbacks": { "type": "integer", "minimum": 0 },
        "failed_rollbacks": { "type": "integer", "minimum": 0 },
        "residuals_discovered": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "matched_comparison": { "type": "object", "additionalProperties": true },
    "scenario_results": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
    "trace_invariants": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "support_state_effect": { "type": "string", "enum": ["none"] },
    "evidence_transition_created": { "type": "boolean", "enum": [false] },
    "non_claims": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": true
}
