{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASI Stack Information Lifecycle Transaction",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "transaction_id", "case_kind", "affected_parties", "purpose_lease", "minimization", "flow_graph", "privacy_evaluation", "rights_request", "rights_receipt", "expected_route", "source_ids", "non_authorities"],
  "properties": {
    "schema_version": {"const": "asi_stack.information_lifecycle_transaction.v1"},
    "transaction_id": {"type": "string", "minLength": 1},
    "case_kind": {"const": "authored_argument_control_no_personal_data_or_privacy_effect"},
    "affected_parties": {
      "type": "object", "additionalProperties": false,
      "required": ["subject_records", "affected_groups", "unknown_or_contested_identity_route"],
      "properties": {
        "subject_records": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "affected_groups": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "unknown_or_contested_identity_route": {"type": "string", "minLength": 1}
      }
    },
    "purpose_lease": {
      "type": "object", "additionalProperties": false,
      "required": ["purpose_id", "processing_operation", "claimed_authority", "jurisdiction", "compatible_with_collection_purpose", "active", "expiry", "recipients", "retention_rule"],
      "properties": {
        "purpose_id": {"type": "string", "minLength": 1}, "processing_operation": {"type": "string", "minLength": 1}, "claimed_authority": {"type": "string", "minLength": 1}, "jurisdiction": {"type": "string", "minLength": 1},
        "compatible_with_collection_purpose": {"const": true}, "active": {"const": true}, "expiry": {"type": "string", "minLength": 1},
        "recipients": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "retention_rule": {"type": "string", "minLength": 1}
      }
    },
    "minimization": {
      "type": "object", "additionalProperties": false,
      "required": ["data_categories", "necessary_categories", "less_data_alternative_tested", "decision_recorded"],
      "properties": {
        "data_categories": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "necessary_categories": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "less_data_alternative_tested": {"const": true}, "decision_recorded": {"const": true}
      }
    },
    "flow_graph": {
      "type": "object", "additionalProperties": false,
      "required": ["required_surfaces", "mapped_surfaces", "known_derivatives", "unknown_copies_recorded", "cross_user_boundary_verified", "obligations_propagated"],
      "properties": {
        "required_surfaces": {"type": "array", "minItems": 12, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "mapped_surfaces": {"type": "array", "minItems": 12, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "known_derivatives": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "unknown_copies_recorded": {"const": true}, "cross_user_boundary_verified": {"const": true}, "obligations_propagated": {"const": true}
      }
    },
    "privacy_evaluation": {
      "type": "object", "additionalProperties": false,
      "required": ["threat_model", "privacy_unit", "adjacency_relation", "formal_mechanism", "accountant", "budget_recorded", "attack_families", "positive_controls_passed", "independent_evaluator", "all_attempts_retained"],
      "properties": {
        "threat_model": {"type": "string", "minLength": 1}, "privacy_unit": {"type": "string", "minLength": 1}, "adjacency_relation": {"type": "string", "minLength": 1}, "formal_mechanism": {"type": "string", "minLength": 1}, "accountant": {"type": "string", "minLength": 1}, "budget_recorded": {"const": true},
        "attack_families": {"type": "array", "minItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "positive_controls_passed": {"const": true}, "independent_evaluator": {"const": true}, "all_attempts_retained": {"const": true}
      }
    },
    "rights_request": {
      "type": "object", "additionalProperties": false,
      "required": ["request_id", "request_type", "identity_verified_proportionately", "scope", "exceptions_reviewed", "appeal_or_remedy_route"],
      "properties": {
        "request_id": {"type": "string", "minLength": 1}, "request_type": {"enum": ["access", "correction", "export", "restriction", "deletion", "ordinary_use"]}, "identity_verified_proportionately": {"const": true}, "scope": {"type": "string", "minLength": 1}, "exceptions_reviewed": {"const": true}, "appeal_or_remedy_route": {"type": "string", "minLength": 1}
      }
    },
    "rights_receipt": {
      "type": "object", "additionalProperties": false,
      "required": ["root_disposition", "recipient_notifications_complete", "known_derivative_dispositions_complete", "storage_outcome", "access_outcome", "behavioral_outcome", "influence_outcome", "privacy_outcome", "legal_compliance_claimed", "residual_owner", "deadline"],
      "properties": {
        "root_disposition": {"type": "string", "minLength": 1}, "recipient_notifications_complete": {"const": true}, "known_derivative_dispositions_complete": {"const": true}, "storage_outcome": {"type": "string", "minLength": 1}, "access_outcome": {"type": "string", "minLength": 1}, "behavioral_outcome": {"type": "string", "minLength": 1}, "influence_outcome": {"type": "string", "minLength": 1}, "privacy_outcome": {"type": "string", "minLength": 1}, "legal_compliance_claimed": {"const": false}, "residual_owner": {"type": "string", "minLength": 1}, "deadline": {"type": "string", "minLength": 1}
      }
    },
    "expected_route": {"const": "accept_bounded_rights_receipt_without_compliance_claim"},
    "source_ids": {"type": "array", "minItems": 9, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "non_authorities": {"type": "array", "minItems": 10, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}
