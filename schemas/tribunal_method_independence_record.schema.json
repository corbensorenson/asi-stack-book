{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://corbensorenson.github.io/asi-stack-book/schemas/tribunal_method_independence_record.schema.json","title":"Tribunal Method Independence Record","type":"object",
  "required":["record_id","source_ids","target_ref","methods","independence_edges","case_results","dissent","verdict","decision","promotion_blockers","non_claims"],
  "properties":{
    "record_id":{"type":"string","minLength":1},"source_ids":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"target_ref":{"type":"string","minLength":1},
    "methods":{"type":"array","minItems":6,"items":{"type":"object","required":["method_id","method_label","independence_group","evidence_refs","result","vote","veto_exercised","veto_reason"],"properties":{"method_id":{"type":"string","minLength":1},"method_label":{"enum":["formal_proof","citation_check","procedural_replay","adversarial_probe","falsification","abstention"]},"independence_group":{"type":"string","minLength":1},"evidence_refs":{"type":"array","items":{"type":"string","minLength":1}},"result":{"enum":["pass","fail","unknown","abstain"]},"vote":{"enum":["accept","revise","reject","abstain"]},"veto_exercised":{"type":"boolean"},"veto_reason":{"type":"string"}},"additionalProperties":false}},
    "independence_edges":{"type":"array","items":{"type":"object","required":["from","to","relation"],"properties":{"from":{"type":"string","minLength":1},"to":{"type":"string","minLength":1},"relation":{"enum":["depends_on","shares_evidence_with"]}},"additionalProperties":false}},
    "case_results":{"type":"array","minItems":3,"items":{"type":"object","required":["case_id","case_kind","evidence_present","verdict"],"properties":{"case_id":{"type":"string","minLength":1},"case_kind":{"enum":["ordinary","empty_case","falsification_target"]},"evidence_present":{"type":"boolean"},"verdict":{"enum":["accept","revise","reject","abstain","blocked"]}},"additionalProperties":false}},
    "dissent":{"type":"object","required":["present","method_ids","text","preserved_in_verdict"],"properties":{"present":{"type":"boolean"},"method_ids":{"type":"array","items":{"type":"string","minLength":1}},"text":{"type":"string"},"preserved_in_verdict":{"type":"boolean"}},"additionalProperties":false},
    "verdict":{"type":"object","required":["state","independent_group_count","default_approval_used","unresolved_refs","required_actions"],"properties":{"state":{"enum":["accept","revise","reject","abstain","blocked"]},"independent_group_count":{"type":"integer","minimum":0},"default_approval_used":{"type":"boolean"},"unresolved_refs":{"type":"array","items":{"type":"string","minLength":1}},"required_actions":{"type":"array","items":{"type":"string","minLength":1}}},"additionalProperties":false},
    "decision":{"type":"object","required":["ordinary_promotion_allowed","support_state_effect"],"properties":{"ordinary_promotion_allowed":{"type":"boolean"},"support_state_effect":{"enum":["none","blocks_promotion","eligible_for_bounded_evidence_review"]}},"additionalProperties":false},
    "promotion_blockers":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"non_claims":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}
  },"additionalProperties":false
}
