{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/semantic_atom.schema.json",
  "title": "Semantic Atom",
  "type": "object",
  "required": [
    "atom_id",
    "source_plan_ref",
    "intent",
    "obligation_refs",
    "inputs",
    "outputs",
    "constraints",
    "dependencies",
    "assumptions",
    "authority_required",
    "validator",
    "validator_status",
    "target",
    "target_artifact_ref",
    "lowering_receipt",
    "repair_scope",
    "residuals",
    "non_claims"
  ],
  "properties": {
    "atom_id": { "type": "string", "minLength": 1 },
    "source_plan_ref": { "type": "string", "minLength": 1 },
    "intent": { "type": "string", "minLength": 1 },
    "obligation_refs": { "type": "array", "items": { "type": "string" } },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "authority_required": { "type": "array", "items": { "type": "string" } },
    "validator": { "type": "string", "minLength": 1 },
    "validator_status": {
      "type": "string",
      "enum": ["not_run", "passed", "failed", "blocked", "residual"]
    },
    "target": { "type": "string", "minLength": 1 },
    "target_artifact_ref": { "type": "string", "minLength": 1 },
    "lowering_receipt": { "type": "string", "minLength": 1 },
    "repair_scope": {
      "type": "string",
      "enum": ["same_atom", "dependent_atoms", "whole_graph", "human_review"]
    },
    "residuals": { "type": "array", "items": { "type": "string" } },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
