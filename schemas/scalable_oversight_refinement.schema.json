{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASI Stack scalable-oversight refinement result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "result_id", "source_sha256", "input_suite", "reachable_stage_count", "route_case_count", "route_coverage", "mutation_count", "mutation_rejection_count", "mutation_receipts", "command_receipts", "witness", "support_state_effect", "non_claims"],
  "properties": {
    "schema_version": {"const": "asi_stack.scalable_oversight_refinement.v1"},
    "result_id": {"const": "scalable-oversight-refinement-2026-07-15-local"},
    "source_sha256": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "input_suite": {"type": "object", "required": ["suite_id", "case_count", "passed_count"], "properties": {"suite_id": {"const": "scalable_oversight_protocol"}, "case_count": {"const": 7}, "passed_count": {"const": 7}}, "additionalProperties": false},
    "reachable_stage_count": {"const": 7},
    "route_case_count": {"const": 58},
    "route_coverage": {"type": "array", "minItems": 58, "maxItems": 58, "items": {"type": "object", "required": ["case_id", "expected_route"], "properties": {"case_id": {"type": "string"}, "expected_route": {"type": "string"}}, "additionalProperties": false}},
    "mutation_count": {"const": 65},
    "mutation_rejection_count": {"const": 65},
    "mutation_receipts": {"type": "array", "minItems": 65, "maxItems": 65, "items": {"type": "object", "required": ["mutation_id", "rejected"], "properties": {"mutation_id": {"type": "string"}, "rejected": {"const": true}}, "additionalProperties": false}},
    "command_receipts": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["command", "exit_code", "output_sha256"], "properties": {"command": {"type": "string"}, "exit_code": {"const": 0}, "output_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false}},
    "witness": {"type": "object", "required": ["terminal_stage", "protocol_version", "receipt_count", "bounded_use_handoff_count", "readmission_count", "support_assignment_count", "external_effect_count"], "properties": {"terminal_stage": {"const": "scoped"}, "protocol_version": {"const": 2}, "receipt_count": {"const": 7}, "bounded_use_handoff_count": {"const": 1}, "readmission_count": {"const": 1}, "support_assignment_count": {"const": 0}, "external_effect_count": {"const": 0}}, "additionalProperties": false},
    "support_state_effect": {"const": "none"},
    "non_claims": {"type": "array", "minItems": 6, "items": {"type": "string"}}
  }
}
