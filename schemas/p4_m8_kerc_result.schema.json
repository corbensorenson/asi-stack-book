{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asi-stack.example/schemas/p4_m8_kerc_result.schema.json",
  "type": "object",
  "required": ["schema_version", "run_id", "preregistration_sha256", "corpus_sha256", "denominators", "slice_results", "native_core_results", "rate_cost_results", "interaction_amortization", "ablations", "attacks", "gate_adjudication", "claim_dispositions", "support_state_effect", "publication_authority", "release_authority"],
  "properties": {
    "schema_version": {"const": "asi_stack.p4_m8_kerc_result.v1"},
    "run_id": {"const": "p4-m8-kerc-runtime-001"},
    "preregistration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "corpus_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "denominators": {"type": "object"},
    "slice_results": {"type": "object"},
    "native_core_results": {"type": "object"},
    "rate_cost_results": {"type": "object"},
    "interaction_amortization": {"type": "array"},
    "ablations": {"type": "array"},
    "attacks": {"type": "object"},
    "gate_adjudication": {"type": "object"},
    "claim_dispositions": {"type": "array"},
    "support_state_effect": {"const": "none_pending_reconciliation"},
    "publication_authority": {"const": "none"},
    "release_authority": {"const": "none"}
  },
  "additionalProperties": true
}
