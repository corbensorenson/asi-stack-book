{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/readiness_check_lifecycle_record.schema.json",
  "title": "Readiness Check Lifecycle Record",
  "type": "object",
  "required": ["record_id", "source_ids", "target_id", "gate_identity", "checks", "stale_dependencies", "containment", "quarantine", "decision", "promotion_blockers", "non_claims"],
  "properties": {
    "record_id": {"type": "string", "minLength": 1},
    "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "target_id": {"type": "string", "minLength": 1},
    "gate_identity": {
      "type": "object",
      "required": ["gate_id", "policy_version", "authority_ref", "evaluated_at", "expires_at"],
      "properties": {
        "gate_id": {"type": "string", "minLength": 1},
        "policy_version": {"type": "string", "minLength": 1},
        "authority_ref": {"type": "string", "minLength": 1},
        "evaluated_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check_id", "applicability", "required", "attempt", "result", "waiver_ref", "evidence_refs", "observed_at", "expires_at"],
        "properties": {
          "check_id": {"type": "string", "minLength": 1},
          "applicability": {"enum": ["applicable", "not_applicable", "unknown"]},
          "required": {"type": "boolean"},
          "attempt": {"enum": ["attempted", "skipped", "not_attempted"]},
          "result": {"enum": ["pass", "fail", "error", "unknown", "not_applicable"]},
          "waiver_ref": {"type": ["string", "null"]},
          "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "observed_at": {"type": ["string", "null"], "format": "date-time"},
          "expires_at": {"type": ["string", "null"], "format": "date-time"}
        },
        "additionalProperties": false
      }
    },
    "stale_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dependency_ref", "state", "invalidates_promotion"],
        "properties": {
          "dependency_ref": {"type": "string", "minLength": 1},
          "state": {"enum": ["current", "stale", "quarantined", "revoked", "unknown"]},
          "invalidates_promotion": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "containment": {
      "type": "object",
      "required": ["previous_state", "next_state", "previous_allowed_routes", "next_allowed_routes"],
      "properties": {
        "previous_state": {"enum": ["open", "limited", "quarantined", "retired"]},
        "next_state": {"enum": ["open", "limited", "quarantined", "retired"]},
        "previous_allowed_routes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "next_allowed_routes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "quarantine": {
      "type": "object",
      "required": ["active", "reason_refs", "owner_ref", "affected_descendant_refs", "disposition_ref"],
      "properties": {
        "active": {"type": "boolean"},
        "reason_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "owner_ref": {"type": ["string", "null"]},
        "affected_descendant_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "disposition_ref": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["state", "ordinary_routing_allowed", "support_state_effect"],
      "properties": {
        "state": {"enum": ["ready", "limited", "quarantined", "blocked", "retired"]},
        "ordinary_routing_allowed": {"type": "boolean"},
        "support_state_effect": {"enum": ["none", "blocks_promotion", "eligible_for_bounded_evidence_review"]}
      },
      "additionalProperties": false
    },
    "promotion_blockers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false
}
