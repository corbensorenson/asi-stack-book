{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/specialist_registry_record.schema.json",
  "title": "Specialist Registry Record",
  "type": "object",
  "required": [
    "specialist_id",
    "registry_epoch",
    "owner",
    "capabilities",
    "authority_envelope",
    "authority_scope",
    "memory_lease_policy",
    "memory_refs",
    "tool_lease_policy",
    "tool_permissions",
    "runtime_tier",
    "cost_profile",
    "readiness_state",
    "quality_predicates",
    "fallback_routes",
    "residual_refs",
    "evidence_refs",
    "route_limitations",
    "non_claims"
  ],
  "properties": {
    "specialist_id": { "type": "string", "minLength": 1 },
    "registry_epoch": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "authority_envelope": { "type": "array", "items": { "type": "string" } },
    "authority_scope": { "type": "string", "minLength": 1 },
    "memory_lease_policy": { "type": "string", "minLength": 1 },
    "memory_refs": { "type": "array", "items": { "type": "string" } },
    "tool_lease_policy": { "type": "string", "minLength": 1 },
    "tool_permissions": { "type": "array", "items": { "type": "string" } },
    "runtime_tier": { "type": "string", "minLength": 1 },
    "cost_profile": { "type": "string", "minLength": 1 },
    "readiness_state": {
      "type": "string",
      "enum": ["unregistered", "candidate", "shadow", "canary", "qualified", "default", "quarantined", "retired"]
    },
    "quality_predicates": { "type": "array", "items": { "type": "string" } },
    "fallback_routes": { "type": "array", "items": { "type": "string" } },
    "residual_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "route_limitations": { "type": "array", "items": { "type": "string" } },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
