{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/evidence_transition_record.schema.json",
  "title": "Evidence Transition Record",
  "type": "object",
  "required": [
    "transition_id",
    "claim_id",
    "claim_surface_refs",
    "claim_record_refs",
    "old_support_state",
    "new_support_state",
    "transition_effect",
    "transition_validity_state",
    "scope_boundary",
    "evidence_roles",
    "transition_reason",
    "required_artifacts",
    "artifact_refs",
    "evidence_packet_refs",
    "source_mapping_refs",
    "verification_command",
    "verification_result",
    "negative_results",
    "negative_evidence_refs",
    "downgrade_triggers",
    "promotion_burden",
    "limitations",
    "review_status",
    "reviewer_refs",
    "reviewer_independence",
    "acceptance_blockers",
    "changelog_ref",
    "support_state_effect",
    "non_claims"
  ],
  "properties": {
    "transition_id": { "type": "string", "minLength": 1 },
    "claim_id": { "type": "string", "minLength": 1 },
    "claim_surface_refs": { "type": "array", "items": { "type": "string" } },
    "claim_record_refs": { "type": "array", "items": { "type": "string" } },
    "old_support_state": {
      "type": "string",
      "enum": ["unsupported", "argument", "source-derived", "prototype-backed", "synthetic-test-backed", "empirical-test-backed", "external-literature-backed", "deprecated", "refuted"]
    },
    "new_support_state": {
      "type": "string",
      "enum": ["unsupported", "argument", "source-derived", "prototype-backed", "synthetic-test-backed", "empirical-test-backed", "external-literature-backed", "deprecated", "refuted"]
    },
    "transition_effect": {
      "type": "string",
      "enum": ["no_change", "upward", "downward", "deprecated", "refuted"]
    },
    "transition_validity_state": {
      "type": "string",
      "enum": [
        "not_checked",
        "shape_validated",
        "artifact_validated",
        "review_accepted",
        "rejected",
        "blocked"
      ]
    },
    "scope_boundary": { "type": "string", "minLength": 1 },
    "evidence_roles": { "type": "array", "items": { "type": "string" } },
    "transition_reason": { "type": "string", "minLength": 1 },
    "required_artifacts": { "type": "array", "items": { "type": "string" } },
    "artifact_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_packet_refs": { "type": "array", "items": { "type": "string" } },
    "source_mapping_refs": { "type": "array", "items": { "type": "string" } },
    "verification_command": { "type": "string", "minLength": 1 },
    "verification_result": {
      "type": "string",
      "enum": ["pass", "fail", "timeout", "mismatch", "not_run"]
    },
    "negative_results": { "type": "array", "items": { "type": "string" } },
    "negative_evidence_refs": { "type": "array", "items": { "type": "string" } },
    "downgrade_triggers": { "type": "array", "items": { "type": "string" } },
    "promotion_burden": { "type": "string", "minLength": 1 },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "review_status": {
      "type": "string",
      "enum": ["open", "accepted", "rejected", "needs_review"]
    },
    "reviewer_refs": { "type": "array", "items": { "type": "string" } },
    "reviewer_independence": { "type": "string", "minLength": 1 },
    "acceptance_blockers": { "type": "array", "items": { "type": "string" } },
    "changelog_ref": { "type": "string", "minLength": 1 },
    "support_state_effect": {
      "type": "string",
      "enum": [
        "none",
        "record_shape_only",
        "argument_only",
        "eligible_for_bounded_evidence_review",
        "blocks_promotion"
      ]
    },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
