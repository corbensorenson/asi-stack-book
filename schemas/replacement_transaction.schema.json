{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/replacement_transaction.schema.json",
  "title": "Replacement Transaction",
  "type": "object",
  "required": [
    "transaction_id",
    "field_id",
    "prior_implementation",
    "candidate_implementation",
    "identity_preservation",
    "precheck_results",
    "qualification_evidence",
    "regression_results",
    "authority_check",
    "evaluator_independence",
    "residual_escrow",
    "rollback_plan",
    "rollback_receipt",
    "approval_record",
    "monitor_window",
    "decision",
    "non_claims"
  ],
  "properties": {
    "transaction_id": { "type": "string", "minLength": 1 },
    "field_id": { "type": "string", "minLength": 1 },
    "prior_implementation": { "type": "string", "minLength": 1 },
    "candidate_implementation": { "type": "string", "minLength": 1 },
    "identity_preservation": { "type": "string", "minLength": 1 },
    "precheck_results": { "type": "array", "items": { "type": "string" } },
    "qualification_evidence": { "type": "array", "items": { "type": "string" } },
    "regression_results": { "type": "array", "items": { "type": "string" } },
    "authority_check": { "type": "string", "minLength": 1 },
    "evaluator_independence": { "type": "string", "minLength": 1 },
    "residual_escrow": { "type": "array", "items": { "type": "string" } },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "rollback_receipt": {
      "type": "object",
      "required": ["prior_artifact", "state_migration_status", "reversible_fields", "irreversible_effects", "dry_run_status", "trigger_conditions", "owner"],
      "properties": {
        "prior_artifact": { "type": "string", "minLength": 1 },
        "state_migration_status": { "type": "string", "minLength": 1 },
        "reversible_fields": { "type": "array", "items": { "type": "string" } },
        "irreversible_effects": { "type": "array", "items": { "type": "string" } },
        "dry_run_status": {
          "type": "string",
          "enum": ["not_run", "pass", "fail", "blocked", "not_applicable"]
        },
        "trigger_conditions": { "type": "array", "items": { "type": "string" } },
        "owner": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "approval_record": { "type": "string", "minLength": 1 },
    "monitor_window": { "type": "string", "minLength": 1 },
    "decision": {
      "type": "string",
      "enum": ["reject", "quarantine", "canary", "commit", "rollback", "retire"]
    },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
