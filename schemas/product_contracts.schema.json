{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/product_contracts.schema.json",
  "title": "ASI Stack Product Contracts",
  "type": "object",
  "required": ["schema_version", "canonical_source_tree", "products", "shared_rules"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["asi_stack.product_contracts.v0"] },
    "canonical_source_tree": { "type": "string", "minLength": 1 },
    "products": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "label", "primary_audience", "reader_question", "entry_points", "source_layers", "navigation_contract", "density_contract", "release_profile", "current_status", "review_gate", "forbidden_inference"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "primary_audience": { "type": "string", "minLength": 1 },
          "reader_question": { "type": "string", "minLength": 1 },
          "entry_points": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "source_layers": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "navigation_contract": { "type": "string", "minLength": 1 },
          "density_contract": { "type": "string", "minLength": 1 },
          "release_profile": { "type": "string", "minLength": 1 },
          "current_status": { "type": "string", "minLength": 1 },
          "review_gate": { "type": "string", "minLength": 1 },
          "forbidden_inference": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "shared_rules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
