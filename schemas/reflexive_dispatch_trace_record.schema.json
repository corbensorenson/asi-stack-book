{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/reflexive_dispatch_trace_record.schema.json",
  "title": "Reflexive Dispatch Trace Record",
  "type": "object",
  "required": [
    "schema_version", "trace_id", "source_id", "event", "ingress",
    "proposals", "qualification", "selection", "plan_nodes", "effect",
    "result", "chronicle", "compilation", "metrics",
    "support_state_effect", "non_claims"
  ],
  "properties": {
    "schema_version": {"const": "asi_stack.reflexive_dispatch_trace.v1"},
    "trace_id": {"type": "string", "minLength": 1},
    "source_id": {"const": "reflexive_router_whitepaper"},
    "event": {
      "type": "object",
      "required": ["event_id", "principal", "authenticated", "received_at", "valid_time", "authority_ref", "context_handles", "resource_budget", "literal_payload"],
      "properties": {
        "event_id": {"type": "string", "minLength": 1},
        "principal": {"type": "string", "minLength": 1},
        "authenticated": {"type": "boolean"},
        "received_at": {"type": "string", "minLength": 1},
        "valid_time": {"type": "string", "minLength": 1},
        "authority_ref": {"type": "string", "minLength": 1},
        "context_handles": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "resource_budget": {"type": "string", "minLength": 1},
        "literal_payload": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "ingress": {
      "type": "object",
      "required": ["mode", "command_authenticated", "requested_route", "fallback_policy", "inference_bypassed"],
      "properties": {
        "mode": {"type": "string", "enum": ["automatic", "forced_route", "direct_command", "compiled_workflow"]},
        "command_authenticated": {"type": "boolean"},
        "requested_route": {"type": "string", "minLength": 1},
        "fallback_policy": {"type": "string", "enum": ["explicit_only", "no_fallback"]},
        "inference_bypassed": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposal_id", "proposer_type", "capability_id", "score", "ood", "composite"],
        "properties": {
          "proposal_id": {"type": "string", "minLength": 1},
          "proposer_type": {"type": "string", "enum": ["command_binding", "deterministic_rule", "learned_router", "semantic_cache", "fallback"]},
          "capability_id": {"type": "string", "minLength": 1},
          "score": {"type": "number"},
          "ood": {"type": "boolean"},
          "composite": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "qualification": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposal_id", "capability_id", "qualified", "obligations", "failures", "receipt_ref"],
        "properties": {
          "proposal_id": {"type": "string", "minLength": 1},
          "capability_id": {"type": "string", "minLength": 1},
          "qualified": {"type": "boolean"},
          "obligations": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "failures": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "receipt_ref": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "selection": {
      "type": "object",
      "required": ["kind", "selected_proposal_ids", "reason", "fallback_used", "terminal_outcome"],
      "properties": {
        "kind": {"type": "string", "enum": ["atomic", "dag", "none"]},
        "selected_proposal_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "reason": {"type": "string", "minLength": 1},
        "fallback_used": {"type": "boolean"},
        "terminal_outcome": {"type": "string", "enum": ["selected", "clarify", "abstain", "deny", "defer", "quarantine", "rollback", "no_route", "contract_rejected"]}
      },
      "additionalProperties": false
    },
    "plan_nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "capability_id", "dependencies", "qualification_ref", "effect_class", "verifier_ref"],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "capability_id": {"type": "string", "minLength": 1},
          "dependencies": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "qualification_ref": {"type": "string", "minLength": 1},
          "effect_class": {"type": "string", "enum": ["none", "read_only", "reversible", "partially_reversible", "irreversible"]},
          "verifier_ref": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "effect": {
      "type": "object",
      "required": ["required", "state", "authority_ref", "receipt_ref", "residuals"],
      "properties": {
        "required": {"type": "boolean"},
        "state": {"type": "string", "enum": ["not_required", "denied", "prepared", "committed", "observed", "verified", "partial", "rolled_back", "compensated", "quarantined", "unknown"]},
        "authority_ref": {"type": "string"},
        "receipt_ref": {"type": "string"},
        "residuals": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": ["result_id", "schema_id", "route_policy_ref", "implementation_refs", "input_digest", "valid_time", "recorded_at", "epistemic_state", "evidence_refs", "verification_state", "effect_receipt_ref", "dependency_refs", "dispatch_provenance_ref", "authoritative_artifact_ref"],
      "properties": {
        "result_id": {"type": "string", "minLength": 1},
        "schema_id": {"type": "string", "minLength": 1},
        "route_policy_ref": {"type": "string", "minLength": 1},
        "implementation_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "input_digest": {"type": "string", "minLength": 1},
        "valid_time": {"type": "string", "minLength": 1},
        "recorded_at": {"type": "string", "minLength": 1},
        "epistemic_state": {"type": "string", "enum": ["observed", "measured", "inferred", "hypothesized", "unknown"]},
        "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "verification_state": {"type": "string", "enum": ["not_required", "pending", "passed", "failed", "disputed"]},
        "effect_receipt_ref": {"type": "string"},
        "dependency_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "dispatch_provenance_ref": {"type": "string", "minLength": 1},
        "authoritative_artifact_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "chronicle": {
      "type": "object",
      "required": ["record_refs", "transaction_time", "valid_time", "update_state"],
      "properties": {
        "record_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "transaction_time": {"type": "string", "minLength": 1},
        "valid_time": {"type": "string", "minLength": 1},
        "update_state": {"type": "string", "enum": ["none", "proposed", "appended", "corrected", "contradicted", "residual"]}
      },
      "additionalProperties": false
    },
    "compilation": {
      "type": "object",
      "required": ["state", "source_trace_refs", "negative_case_refs", "differential_test_ref", "expiry", "decompilation_route"],
      "properties": {
        "state": {"type": "string", "enum": ["ineligible", "candidate", "shadow", "qualified", "quarantined", "decompiled"]},
        "source_trace_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "negative_case_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "differential_test_ref": {"type": "string"},
        "expiry": {"type": "string", "minLength": 1},
        "decompilation_route": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "required": ["useful_outcome_state", "fast_path", "wrong_fast_path", "route_regret_state", "total_cost_record_ref"],
      "properties": {
        "useful_outcome_state": {"type": "string", "enum": ["not_measured", "useful", "not_useful", "unknown"]},
        "fast_path": {"type": "boolean"},
        "wrong_fast_path": {"type": "boolean"},
        "route_regret_state": {"type": "string", "enum": ["not_measured", "measured", "unknown"]},
        "total_cost_record_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "support_state_effect": {"const": "none"},
    "non_claims": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false
}
