{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/governed_trace_invariants_result.schema.json",
  "title": "Governed Cross-Stack Trace Invariants Result",
  "type": "object",
  "required": [
    "schema_version",
    "result_id",
    "recorded_date",
    "source_result_ref",
    "source_result_sha256",
    "logical_time_model",
    "authority_handoffs",
    "revocation_effect_attempts",
    "evidence_events",
    "residual_deltas",
    "final_open_residuals",
    "causal_edges",
    "invariant_results",
    "negative_controls",
    "lean_fixture_alignment",
    "support_state_effect",
    "non_claims"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["asi_stack.governed_trace_invariants_result.v0"] },
    "result_id": { "type": "string", "minLength": 1 },
    "recorded_date": { "type": "string", "minLength": 1 },
    "source_result_ref": { "type": "string", "minLength": 1 },
    "source_result_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "logical_time_model": { "type": "string", "minLength": 1 },
    "authority_handoffs": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
    "revocation_effect_attempts": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
    "evidence_events": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
    "residual_deltas": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
    "final_open_residuals": { "type": "integer", "minimum": 0 },
    "causal_edges": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
    "invariant_results": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "negative_controls": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "lean_fixture_alignment": { "type": "object", "additionalProperties": true },
    "support_state_effect": { "type": "string", "enum": ["none"] },
    "non_claims": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
