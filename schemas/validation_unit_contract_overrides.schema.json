{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/validation_unit_contract_overrides.schema.json",
  "title": "Validation Unit Contract Overrides",
  "type": "object",
  "required": ["schema_version", "contracts", "non_claims"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["asi_stack.validation_unit_contract_overrides.v0"] },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["script", "args", "input_contract", "input_artifacts", "output_contract", "output_assertions", "claim_scope", "negative_controls", "negative_control_cases", "prohibited_inference", "contract_precision", "semantic_review_state"],
        "properties": {
          "script": { "type": "string", "minLength": 1 },
          "args": { "type": "array", "items": { "type": "string" } },
          "input_contract": { "type": "string", "minLength": 1 },
          "input_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "output_contract": { "type": "string", "minLength": 1 },
          "output_assertions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "claim_scope": { "type": "string", "minLength": 1 },
          "negative_controls": { "type": "string", "enum": ["validator_owned"] },
          "negative_control_cases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "prohibited_inference": { "type": "string", "minLength": 1 },
          "contract_precision": { "type": "string", "enum": ["exact_high_impact"] },
          "semantic_review_state": { "type": "string", "enum": ["internal_contract_audit_not_independent"] }
        },
        "additionalProperties": false
      }
    },
    "non_claims": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
