{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corbensorenson.github.io/asi-stack-book/schemas/self_improvement_transition.schema.json",
  "title": "Self-Improvement Transition",
  "type": "object",
  "required": [
    "transition_id",
    "trigger_residual",
    "field_id",
    "proposal",
    "cheaper_interventions_tried",
    "protected_invariants",
    "evaluator_independence",
    "replacement_transaction",
    "governance_approval",
    "monitor_window",
    "rollback_path",
    "outcome_state"
  ],
  "properties": {
    "transition_id": { "type": "string", "minLength": 1 },
    "trigger_residual": { "type": "string", "minLength": 1 },
    "field_id": { "type": "string", "minLength": 1 },
    "proposal": { "type": "string", "minLength": 1 },
    "cheaper_interventions_tried": { "type": "array", "items": { "type": "string" } },
    "protected_invariants": { "type": "array", "items": { "type": "string" } },
    "evaluator_independence": { "type": "string", "minLength": 1 },
    "replacement_transaction": { "type": "string", "minLength": 1 },
    "governance_approval": { "type": "string", "minLength": 1 },
    "monitor_window": { "type": "string", "minLength": 1 },
    "rollback_path": { "type": "string", "minLength": 1 },
    "outcome_state": {
      "type": "string",
      "enum": ["proposed", "rejected", "quarantined", "canary", "promoted", "rolled_back", "retired"]
    }
  },
  "additionalProperties": false
}
